---
const year = 2026;
const cols = [
  {
    h: 'Systems',
    items: [
      { label: 'All systems', href: '/systems/' },
      { label: 'Entry & Access', href: '/systems/' },
      { label: 'Lighting & Power', href: '/systems/' },
      { label: 'Comfort & Climate', href: '/systems/' },
      { label: 'Energy storage', href: '/energy/' },
    ],
  },
  {
    h: 'Decide',
    items: [
      { label: 'How pricing works', href: '/how-it-works/' },
      { label: 'No monthly fee', href: '/no-monthly-fee/' },
      { label: 'Homynex vs Vivint', href: '/homynex-vs-vivint/' },
      { label: 'FAQ', href: '/faq/' },
      { label: 'For builders', href: '/builders/' },
    ],
  },
  {
    h: 'Company',
    items: [
      { label: 'About Homynex', href: '/about/' },
      { label: 'The Homynex App', href: '/app/' },
      { label: 'Book a walkthrough', href: '/contact/' },
      { label: 'Warranty & service', href: '/contact/' },
    ],
  },
];
---

<footer class="ft">
  <div class="ft-inner">
    <div class="ft-grid">
      <div class="ft-brand">
        <div class="ft-logo">
          <span class="ft-mark" aria-hidden="true">H</span>
          <div>
            <div class="ft-word">HOMYNEX</div>
            <div class="ft-sub">by SmartSync Electric Ltd</div>
          </div>
        </div>
        <p class="ft-line">Whole-home smart, no monthly fee — installed by your local electrician.</p>
        <p class="ft-para">Eleven integrated systems — entry, lighting, climate, security, audio and energy — in one app, installed by your own licensed electrician. A one-time purchase with no monthly fee: homeowners own it outright, not a subscription.</p>
        <a href="mailto:hello@homynex.com" class="ft-email">hello@homynex.com</a>
      </div>
      {cols.map((col) => (
        <div class="ft-col">
          <div class="ft-h">{col.h}</div>
          <div class="ft-links">
            {col.items.map((it) => (<a href={it.href}>{it.label}</a>))}
          </div>
        </div>
      ))}
    </div>
    <div class="ft-bottom">
      <span>© {year} SmartSync Electric Ltd · Homynex</span>
      <span>Whole-home smart for Utah builders &amp; homeowners · homynex.com</span>
    </div>
  </div>
</footer>

<style>
  .ft { background: var(--dark); color: var(--on-dark); font-family: 'Hanken Grotesk', sans-serif; }
  .ft-inner { max-width: 1240px; margin: 0 auto; padding: 80px 32px 40px; }
  .ft-grid { display: grid; grid-template-columns: 1.7fr 1fr 1fr 1fr; gap: 40px; }
  .ft-logo { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
  .ft-mark {
    width: 36px; height: 36px; border-radius: 9px; background: var(--green); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font: 800 16px/1 'Schibsted Grotesk', sans-serif;
  }
  .ft-word { font: 700 20px/1 'Schibsted Grotesk', sans-serif; }
  .ft-sub { font-size: 12px; color: #9b9488; margin-top: 5px; }
  .ft-line {
    font: 500 21px/1.3 'Schibsted Grotesk', sans-serif; letter-spacing: -0.01em;
    max-width: 20ch; margin: 0 0 16px;
  }
  .ft-para {
    font-size: 14px; line-height: 1.6; color: #b7b1a4; max-width: 46ch; margin: 0 0 20px;
  }
  .ft-email {
    color: var(--on-dark); font-weight: 600; font-size: 15px; text-decoration: none;
    border-bottom: 1px solid #3a352e; padding-bottom: 3px;
  }
  .ft-email:hover { border-bottom-color: var(--mint); color: var(--mint); }
  .ft-h { font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #9b9488; margin-bottom: 18px; }
  .ft-links { display: flex; flex-direction: column; gap: 11px; }
  .ft-links a { color: #e4dfd5; text-decoration: none; font-size: 14.5px; }
  .ft-links a:hover { color: #fff; }
  .ft-bottom {
    margin-top: 56px; padding-top: 24px; border-top: 1px solid var(--dark-line);
    display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap;
    font-size: 13px; color: #9b9488;
  }
  @media (max-width: 860px) {
    .ft-inner { padding: 56px 22px 36px; }
    .ft-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
    .ft-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .ft-grid { grid-template-columns: 1fr; }
  }
</style>
