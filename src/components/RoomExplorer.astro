---
import { systems, hotspots } from '../data/systems.js';
import { buildScene } from '../lib/isometric.js';

const { svg, spots } = buildScene(hotspots);
const defaultId = 'entry';
const spotData = hotspots.map((h) => ({ ...h, ...spots[h.id], system: systems[h.sysIdx] }));

const stats = [
  { v: '11', l: 'integrated systems, one supplier' },
  { v: '1', l: 'app for the whole home' },
  { v: '$0', l: 'monthly fees, ever' },
  { v: '2-yr', l: 'parts & labor warranty' },
];
---

<section class="rx" data-reveal>
  <div class="rx-wrap">
    <div class="rx-head">
      <div>
        <div class="rx-kicker">Interactive · room explorer</div>
        <h2 class="rx-title">See it integrated</h2>
      </div>
      <p class="rx-sub">Tap a hotspot to see which Homynex systems live in each part of the home.</p>
    </div>

    <div class="rx-grid">
      <div class="rx-stage">
        <div class="rx-scene" set:html={svg}></div>
        {spotData.map((h) => (
          <button
            class={h.id === defaultId ? 'rx-hot on' : 'rx-hot'}
            data-spot={h.id}
            data-default={h.id === defaultId ? 'true' : 'false'}
            style={`top:${h.top}%;left:${h.left}%`}
            aria-pressed={h.id === defaultId ? 'true' : 'false'}
            aria-label={`${h.label} — ${h.system.name}`}
          >
            <span class="rx-dot" aria-hidden="true"></span>
            <span class="rx-hlabel">{h.label}</span>
          </button>
        ))}
      </div>

      <div class="rx-panels">
        {spotData.map((h) => (
          <div class="rx-panel" data-panel={h.id} hidden={h.id !== defaultId}>
            <div class="rx-tag">{h.system.tag}</div>
            <div class="rx-name-row">
              <span class="rx-n">{h.system.n}</span>
              <h3>{h.system.name}</h3>
            </div>
            <p class="rx-desc">{h.system.desc}</p>
            <ul class="rx-prod">
              {h.system.products.map((p) => (<li>{p}</li>))}
            </ul>
            <a href={h.system.href} class="rx-link">Explore this system →</a>
          </div>
        ))}
      </div>
    </div>

    <div class="rx-stats">
      {stats.map((s) => (
        <div class="rx-stat">
          <div class="rx-stat-v">{s.v}</div>
          <div class="rx-stat-l">{s.l}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Accessible hotspot ↔ panel toggle. Buttons handle Enter/Space natively.
  const rx = document.querySelector('.rx');
  if (rx) {
    const hots = Array.from(rx.querySelectorAll<HTMLButtonElement>('.rx-hot'));
    const panels = Array.from(rx.querySelectorAll<HTMLElement>('.rx-panel'));
    const activate = (id: string | undefined) => {
      if (!id) return;
      hots.forEach((h) => {
        const on = h.dataset.spot === id;
        h.classList.toggle('on', on);
        h.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      panels.forEach((p) => { p.hidden = p.dataset.panel !== id; });
    };
    hots.forEach((h) => h.addEventListener('click', () => activate(h.dataset.spot)));
  }
</script>

<style>
  .rx { background: var(--dark); color: var(--on-dark); }
  .rx-wrap { max-width: 1240px; margin: 0 auto; padding: 88px 32px; }
  .rx-head {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 20px; margin-bottom: 34px; flex-wrap: wrap;
  }
  .rx-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--mint); margin-bottom: 16px;
  }
  .rx-title { margin: 0; font-weight: 700; font-size: clamp(30px, 4vw, 52px); letter-spacing: -0.025em; line-height: 1.02; }
  .rx-sub { margin: 0; max-width: 38ch; color: var(--on-dark-muted); font-size: 16px; line-height: 1.55; }

  .rx-grid { display: grid; grid-template-columns: 1fr 360px; gap: 22px; }
  .rx-stage {
    position: relative; border-radius: 18px; overflow: hidden;
    background: radial-gradient(125% 120% at 50% 0%, #2a251e 0%, #161412 68%);
    border: 1px solid var(--dark-line); aspect-ratio: 980 / 620;
  }
  .rx-scene { position: absolute; inset: 0; }

  .rx-hot {
    position: absolute; transform: translate(-50%, -50%);
    display: flex; flex-direction: column; align-items: center; gap: 7px;
    background: none; border: 0; padding: 10px; margin: 0; cursor: pointer;
    z-index: 3; min-width: 44px; min-height: 44px; /* touch target */
  }
  .rx-hot.on { z-index: 6; }
  .rx-dot {
    width: 18px; height: 18px; border-radius: 50%; border: 2.5px solid #fff;
    background: rgba(255, 255, 255, 0.7); box-shadow: 0 2px 9px rgba(0, 0, 0, 0.45);
    transition: all 0.2s ease;
  }
  .rx-hot:hover .rx-dot { background: var(--mint); }
  .rx-hot.on .rx-dot {
    width: 24px; height: 24px; background: var(--green);
    box-shadow: 0 0 0 7px rgba(30, 91, 67, 0.32); animation: wfpulse 2.2s infinite;
  }
  .rx-hlabel {
    font: 600 9.5px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.04em; text-transform: uppercase;
    padding: 4px 8px; border-radius: 999px; white-space: nowrap;
    background: rgba(22, 20, 18, 0.82); color: #fff; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
    opacity: 0.82; transition: all 0.2s ease;
  }
  .rx-hot.on .rx-hlabel { background: var(--green); opacity: 1; }

  .rx-panels { position: relative; }
  .rx-panel {
    background: var(--dark-2); border: 1px solid var(--dark-line); border-radius: 18px;
    padding: 28px; display: flex; flex-direction: column; height: 100%;
  }
  /* author .rx-panel{display:flex} would otherwise beat the UA [hidden] rule,
     leaving every panel visible — pin hidden panels back to display:none. */
  .rx-panel[hidden] { display: none; }
  .rx-tag {
    font: 600 11px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--mint);
  }
  .rx-name-row { display: flex; align-items: baseline; gap: 10px; margin-top: 12px; }
  .rx-n { font: 700 15px/1 'Schibsted Grotesk', sans-serif; color: var(--terra); flex: none; }
  .rx-name-row h3 { margin: 0; font-weight: 600; font-size: 22px; letter-spacing: -0.01em; color: #fff; }
  .rx-desc { margin: 14px 0 18px; font-size: 14.5px; line-height: 1.55; color: var(--on-dark-muted); }
  .rx-prod {
    list-style: none; margin: 0; padding: 16px 0 0; border-top: 1px solid var(--dark-line);
    display: flex; flex-direction: column; gap: 11px;
  }
  .rx-prod li {
    position: relative; padding-left: 17px; font-size: 14px; color: #e4dfd5; font-weight: 500; line-height: 1.35;
  }
  .rx-prod li::before {
    content: ''; position: absolute; left: 0; top: 7px; width: 6px; height: 6px;
    border-radius: 50%; background: var(--mint);
  }
  .rx-link {
    margin-top: 22px; align-self: flex-start; text-decoration: none;
    background: var(--green); color: #fff; font-weight: 600; font-size: 14px;
    padding: 13px 20px; border-radius: 999px; transition: transform 0.2s ease, background 0.2s ease;
  }
  .rx-link:hover { transform: translateY(-2px); background: var(--green-2); }

  /* stats woven into the base of the integration block */
  .rx-stats {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
    margin-top: 52px; padding-top: 36px; border-top: 1px solid var(--dark-line);
  }
  .rx-stat-v { font: 700 clamp(30px, 3.4vw, 46px)/1 'Schibsted Grotesk', sans-serif; letter-spacing: -0.02em; color: #fff; }
  .rx-stat-l { font-size: 13.5px; color: var(--on-dark-muted); margin-top: 9px; font-weight: 500; }

  @media (max-width: 880px) {
    .rx-wrap { padding: 64px 22px; }
    .rx-grid { grid-template-columns: 1fr; }
    .rx-hlabel { display: none; } /* declutter dots on small screens */
    .rx-stats { grid-template-columns: 1fr 1fr; gap: 28px 20px; margin-top: 40px; }
  }
</style>
