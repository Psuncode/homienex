---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const links = [
  { label: 'Home', href: '/' },
  { label: 'The 11 systems', href: '/systems/' },
  { label: 'Book a walkthrough', href: '/contact/' },
];
---

<Base title="Page not found | Homynex">
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <Nav />

  <section class="nf">
    <div class="nf-inner">
      <p class="nf-kicker">404</p>
      <h1 class="nf-h1">We couldn't find that page.</h1>
      <p class="nf-sub">
        The link may be old or mistyped. Here are a few good places to pick up where you left off.
      </p>
      <ul class="nf-pills">
        {links.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
      </ul>
    </div>
  </section>

  <Footer />
</Base>

<style>
  .nf {
    max-width: 1240px; margin: 0 auto;
    padding: clamp(80px, 14vh, 160px) 32px clamp(80px, 12vh, 140px);
    display: flex; justify-content: center; text-align: center;
  }
  .nf-inner { max-width: 640px; }
  .nf-kicker {
    font: 700 13px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--terra); margin: 0 0 18px;
  }
  .nf-h1 {
    margin: 0; font-weight: 700; font-size: clamp(36px, 6vw, 64px); line-height: 1.0;
    letter-spacing: -0.03em; color: var(--ink);
  }
  .nf-sub {
    margin: 22px auto 0; font-size: clamp(16px, 1.6vw, 19px); line-height: 1.6; color: var(--muted);
    max-width: 46ch;
  }
  .nf-pills {
    display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
    list-style: none; margin: 36px 0 0; padding: 0;
  }
  .nf-pills a {
    text-decoration: none; font: 600 15px/1 'Hanken Grotesk', sans-serif; color: var(--ink);
    background: #fff; border: 1px solid var(--line); padding: 14px 24px; border-radius: 999px;
    display: inline-block; transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .nf-pills a:hover { transform: translateY(-2px); border-color: var(--green); color: var(--green); }
  @media (max-width: 560px) {
    .nf { padding: 72px 22px 80px; }
  }
</style>
