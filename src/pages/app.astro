---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const features = [
  { n: '01', t: 'Multi-home management', d: 'Manage multiple homes and all their devices from a single account.' },
  { n: '02', t: 'Smart device control', d: 'Centrally control every device; pin favorites to the home screen.' },
  { n: '03', t: 'Room-based management', d: 'Add and organize devices by room for clearer, faster control.' },
  { n: '04', t: 'Scene setup & execution', d: 'Create, edit and one-tap preset scenes for any moment.' },
  { n: '05', t: 'Family sharing', d: 'Add family members to share devices and scene settings instantly.' },
  { n: '06', t: 'Home call & video doorbell', d: 'Make home calls and answer video doorbell calls from the panel.' },
];
const steps = [
  { n: '1', t: 'Create your account', d: 'One Homynex account manages every home you add.' },
  { n: '2', t: 'Add devices by room', d: 'Pair devices and organize them room by room.' },
  { n: '3', t: 'Build your scenes', d: 'Automate lighting, climate, blinds and more with one tap.' },
];
---

<Base
  title="The Homynex App — Every Device, One Screen"
  description="Manage your whole home from a single app — multi-home management, room control, scenes, family sharing and video doorbell. Powered by Tuya, works with Alexa. No monthly fee."
>
  <Nav current="app" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-text">
      <p class="hero-kicker">The Homynex App · powered by Tuya</p>
      <h1 class="hero-h1">Every device,<br />one screen</h1>
      <p class="hero-sub">Manage and control every home device from a single app, bringing convenience and intelligence to modern family life — and never a monthly fee.</p>
      <div class="app-badges">
        <span class="badge">
          <svg width="17" height="20" viewBox="0 0 384 512" fill="#fff" aria-hidden="true"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C73.3 141.2 18 184.6 18 273c0 26.1 4.8 53.1 14.4 80.9 12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.1zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
          <span class="badge-txt"><small>Download on the</small><strong>App Store</strong></span>
        </span>
        <span class="badge">
          <svg width="16" height="18" viewBox="0 0 24 24" aria-hidden="true"><path fill="#34A853" d="M3.6 2.1 13 11.5 3.6 21z" opacity=".9"/><path fill="#FBBC04" d="m16.4 8.3 3.2 1.8c1 .6 1 1.9 0 2.5l-3.2 1.8L13 12.6z"/><path fill="#EA4335" d="M3.6 2.1 13 7.4l-3.4 3.4z"/><path fill="#4285F4" d="M3.6 21 13 15.7l-3.4-3.4z"/></svg>
          <span class="badge-txt"><small>Get it on</small><strong>Google Play</strong></span>
        </span>
      </div>
    </div>
    <img
      src="/catalog_images/p19_0.jpg"
      alt="The Homynex app home screen controlling devices room by room"
      class="hero-img"
      fetchpriority="high"
      decoding="async"
      width="540"
      height="520"
    />
  </section>

  <!-- FEATURES -->
  <section class="features" data-reveal>
    <h2 class="features-h2">Built around how you live</h2>
    <div class="feature-grid">
      {features.map((f) => (
        <div class="feature-card">
          <div class="feature-chip">{f.n}</div>
          <h3>{f.t}</h3>
          <p>{f.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- STEPS BAND -->
  <section class="steps" data-reveal>
    <div class="steps-inner">
      <div class="steps-text">
        <p class="steps-kicker">One account, every home</p>
        <h2 class="steps-h2">Up and running in minutes</h2>
        <div class="steps-list">
          {steps.map((s) => (
            <div class="step">
              <span class="step-n">{s.n}</span>
              <div>
                <div class="step-t">{s.t}</div>
                <div class="step-d">{s.d}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <img
        src="/catalog_images/p19_2.jpg"
        alt="The Homynex app room and scene control screens"
        class="steps-img"
        loading="lazy"
        decoding="async"
        width="560"
        height="460"
      />
    </div>
  </section>

  <!-- CTA -->
  <section class="cta" data-reveal>
    <div class="cta-inner">
      <h2 class="cta-h2">One app for the whole home — and no monthly fee.</h2>
      <a href="/contact/" class="btn-dark">Book a walkthrough</a>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ---------- shared badges ---------- */
  .app-badges { display: flex; gap: 12px; margin-top: 30px; flex-wrap: wrap; }
  .badge { background: var(--ink); color: #fff; border-radius: 13px; padding: 11px 20px; display: flex; align-items: center; gap: 11px; white-space: nowrap; }
  .badge svg { flex: none; }
  .badge-txt { line-height: 1.15; display: flex; flex-direction: column; }
  .badge-txt small { font-size: 10px; color: #b7b1a4; }
  .badge-txt strong { font: 600 16px/1 'Schibsted Grotesk', sans-serif; }

  /* ---------- shared dark pill button ---------- */
  .btn-dark {
    text-decoration: none; background: var(--ink); color: #fff; font-weight: 600; font-size: 16px;
    padding: 17px 32px; border-radius: 999px; display: inline-block;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .btn-dark:hover { transform: translateY(-2px); background: var(--green-2); }

  /* ---------- hero ---------- */
  .hero {
    max-width: 1240px; margin: 0 auto; padding: 64px 32px 40px;
    display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 48px; align-items: center;
  }
  .hero-kicker {
    font: 600 13px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--green); margin: 0 0 18px;
  }
  .hero-h1 {
    margin: 0; font-weight: 700; font-size: clamp(44px, 6vw, 82px);
    line-height: 0.98; letter-spacing: -0.03em;
  }
  .hero-sub { margin: 22px 0 0; max-width: 46ch; font-size: 18px; line-height: 1.6; color: var(--muted); }
  .hero-img {
    width: 100%; height: clamp(420px, 48vw, 520px); object-fit: cover;
    border-radius: 32px; background: #ece7dd;
  }

  /* ---------- features ---------- */
  .features { max-width: 1240px; margin: 0 auto; padding: 56px 32px; }
  .features-h2 { margin: 0 0 36px; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; }
  .feature-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .feature-card { background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 28px; }
  .feature-chip {
    width: 44px; height: 44px; border-radius: 12px; background: #e7efe8;
    display: flex; align-items: center; justify-content: center;
    font: 700 16px/1 'Schibsted Grotesk', sans-serif; color: var(--green);
  }
  .feature-card h3 { margin: 20px 0 8px; font-weight: 600; font-size: 20px; letter-spacing: -0.01em; }
  .feature-card p { margin: 0; font-size: 14.5px; line-height: 1.55; color: var(--muted-2); }

  /* ---------- steps band ---------- */
  .steps { background: var(--green); color: #fff; }
  .steps-inner {
    max-width: 1240px; margin: 0 auto; padding: 80px 32px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center;
  }
  .steps-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; text-transform: uppercase; letter-spacing: 0.14em;
    color: var(--mint); margin: 0 0 16px;
  }
  .steps-h2 { margin: 0 0 28px; font-weight: 700; font-size: clamp(28px, 3.4vw, 44px); letter-spacing: -0.02em; line-height: 1.05; }
  .steps-list { display: flex; flex-direction: column; gap: 20px; }
  .step { display: flex; gap: 16px; align-items: flex-start; border-top: 1px solid rgba(255, 255, 255, 0.18); padding-top: 18px; }
  .step-n { font: 700 22px/1 'Schibsted Grotesk', sans-serif; color: var(--mint); }
  .step-t { font: 600 18px/1.1 'Schibsted Grotesk', sans-serif; }
  .step-d { font-size: 14.5px; line-height: 1.5; color: #d6e7de; margin-top: 5px; }
  .steps-img { width: 100%; height: clamp(320px, 38vw, 460px); object-fit: cover; border-radius: 24px; background: #2f7e5c; }

  /* ---------- cta ---------- */
  .cta { max-width: 1240px; margin: 0 auto; padding: 88px 32px; }
  .cta-inner { text-align: center; }
  .cta-h2 {
    margin: 0 auto; max-width: 20ch; font-weight: 700; font-size: clamp(30px, 4.2vw, 52px);
    line-height: 1.04; letter-spacing: -0.025em;
  }
  .cta .btn-dark { margin-top: 30px; }

  /* ---------- responsive ---------- */
  @media (max-width: 880px) {
    .hero { grid-template-columns: 1fr; gap: 32px; }
    .hero-img { order: -1; height: clamp(320px, 70vw, 480px); }
    .feature-grid { grid-template-columns: 1fr 1fr; }
    .steps-inner { grid-template-columns: 1fr; gap: 36px; }
    .steps-img { order: -1; height: clamp(280px, 64vw, 420px); }
  }
  @media (max-width: 560px) {
    .hero { padding: 40px 22px 28px; }
    .features { padding: 44px 22px; }
    .feature-grid { grid-template-columns: 1fr; }
    .steps-inner { padding: 60px 22px; }
    .cta { padding: 60px 22px; }
  }
</style>
