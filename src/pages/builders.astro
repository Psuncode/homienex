---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const values = [
  {
    n: '01',
    t: 'One supplier, a shorter sub list',
    d: 'Eleven integrated systems come from a single source — entry, lighting, climate, security, audio and energy. One vendor to spec, one number to call, fewer trades to coordinate on the schedule.',
  },
  {
    n: '02',
    t: 'A standardized spec across every home',
    d: 'Lock one ecosystem to a floor plan and repeat it across the development. Every home runs the same systems on the same platform — no per-house guesswork, no mismatched gadgets.',
  },
  {
    n: '03',
    t: 'One app you hand over',
    d: 'The buyer gets the whole home on a single app — rooms, scenes, family sharing. You hand over a development that just works, instead of a binder of disconnected device manuals.',
  },
  {
    n: '04',
    t: 'No monthly fee makes it an easier sell',
    d: 'It is a one-time purchase the homeowner owns outright — no contract, no monitoring bill. That is a cleaner story at the design center than a subscription that follows the buyer home.',
  },
  {
    n: '05',
    t: 'Quoted per plan, to fit the budget',
    d: 'Each scope is quoted as one package per floor plan, not itemized device by device, so it drops cleanly into the upgrade budget you already present.',
  },
  {
    n: '06',
    t: 'Installed by the electrician on site',
    d: 'The licensed local electrician already wiring the home installs it during the build. No proprietary technician, no extra trade to schedule, no service lock-in for your buyer.',
  },
];

const tiers = [
  {
    name: 'Essentials',
    tag: 'The foundation',
    lead: 'The core of a connected home, ready on day one.',
    systems: ['Smart entry & access', 'Lighting & power', 'The Homynex app'],
    note: 'Entry, lighting and one app — the baseline every plan can carry.',
  },
  {
    name: 'Enhanced',
    tag: 'Everyday comfort',
    lead: 'Adds the systems buyers feel every day.',
    systems: [
      'Everything in Essentials',
      'Comfort & climate control',
      'Security cameras & sensors',
      'Whole-home audio',
    ],
    note: 'Climate, cameras and audio layered onto the foundation.',
  },
  {
    name: 'Whole-home',
    tag: 'All eleven systems',
    lead: 'The complete ecosystem, energy and backup included.',
    systems: [
      'Everything in Enhanced',
      'Energy storage & solar',
      'EV charging',
      'Backup power & monitoring',
    ],
    note: 'All eleven integrated systems, working together in one app.',
  },
];

const channel = [
  {
    n: '01',
    t: 'Zero-inventory onboarding',
    d: 'Partner without buying stock up front. There is no warehouse to fill and no inventory to carry — you spec the package and we supply it for the build.',
  },
  {
    n: '02',
    t: 'Channel pricing for partners',
    d: 'Builders and developers buy at partner pricing built for the trade, so the smart-home upgrade lands inside the budget you already quote.',
  },
  {
    n: '03',
    t: 'A sample & spec board',
    d: 'Put the systems in front of buyers at the design center — a sample and spec board that makes the three scopes easy to choose between, plan by plan.',
  },
  {
    n: '04',
    t: 'Quoted per plan',
    d: 'We quote one package per floor plan, not per device, so adding Homynex to a development is a single line — predictable across every home you build.',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Homynex for builders',
  serviceType: 'Whole-home smart system for spec homes',
  description:
    'Homynex lets a builder spec one whole-home smart system — eleven integrated systems in one app — as a standardized spec-home upgrade across a development. A one-time purchase with no monthly fee, installed by a licensed local electrician and quoted as one package per floor plan.',
  provider: {
    '@type': 'Organization',
    name: 'Homynex',
    url: 'https://homienex.com',
    parentOrganization: { '@type': 'Organization', name: 'SmartSync Electric Ltd' },
  },
  areaServed: { '@type': 'State', name: 'Utah' },
  offers: {
    '@type': 'Offer',
    priceSpecification: {
      '@type': 'PriceSpecification',
      priceCurrency: 'USD',
    },
  },
};
---

<Base
  title="Homynex for Builders — Spec-Home Smart Packages, No Monthly Fee"
  description="Spec one smart ecosystem across every home you build. Standardized Essentials/Enhanced/Whole-home packages, channel pricing, zero-inventory onboarding, installed by local electricians. No monthly fee for your buyers."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <Nav current="builders" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-media">
      <picture style="display:contents">
        <source type="image/webp" srcset="/catalog_images/p51_1.webp" />
        <img
          src="/catalog_images/p51_1.jpg"
          alt="Modern living room at dusk with integrated Homynex lighting, climate and shades, ready to spec across a development"
          class="hero-img"
          fetchpriority="high"
          decoding="async"
          width="1320"
          height="720"
        />
      </picture>
      <div class="hero-scrim" aria-hidden="true"></div>
    </div>
    <div class="hero-content">
      <p class="hero-kicker">For builders &amp; developers</p>
      <h1 class="hero-h1">Spec one smart ecosystem across every home you build</h1>
      <p class="hero-sub">
        One supplier, one app, standardized across the development — and <strong>no monthly fee</strong>
        for your buyers. Installed by the local electrician already on site, quoted as one package per
        floor plan.
      </p>
      <div class="hero-cta-row">
        <a href="/contact/" class="btn-primary">Book a builder walkthrough</a>
        <a href="/systems/" class="btn-ghost">Explore the 11 systems</a>
      </div>
      <ul class="hero-chips">
        <li>One supplier</li>
        <li>$0 / month for buyers</li>
        <li>Zero-inventory onboarding</li>
      </ul>
    </div>
  </section>

  <!-- WHY BUILDERS STANDARDIZE -->
  <section class="why" data-reveal>
    <div class="why-inner">
      <div class="why-head">
        <p class="why-kicker">Why builders standardize on Homynex</p>
        <h2>One ecosystem, repeated across the development.</h2>
        <p class="why-sub">
          Spec it once and carry the same smart home from plan to plan — fewer trades, one app to
          hand over, and a cleaner story at the design center.
        </p>
      </div>
      <div class="why-cards">
        {values.map((v) => (
          <div class="why-card">
            <div class="why-n">{v.n}</div>
            <h3>{v.t}</h3>
            <p>{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CITABLE PASSAGE -->
  <section class="cite" data-reveal>
    <div class="cite-inner">
      <p class="cite-kicker">Homynex for builders</p>
      <p class="cite-text">
        Homynex lets a builder spec one whole-home smart system —
        <strong>eleven integrated systems in one app</strong> — as a standardized spec-home upgrade
        across a development. It is a <strong>one-time purchase with no monthly fee</strong>, installed
        by a licensed local electrician during the build, and quoted as one package per floor plan, not
        per device. Builders onboard with <strong>zero inventory</strong> and channel pricing: there is
        no stock to carry and partner pricing is built for the trade, so the smart-home upgrade fits the
        budget you already present. Every home in the development runs the same systems on the same
        platform — entry, lighting, climate, security, audio and energy — and the buyer owns it outright,
        with no contract and no monitoring bill. Homynex is supplied by SmartSync Electric, serving
        Utah's Wasatch Front.
      </p>
      <ul class="cite-points">
        <li><strong>One supplier.</strong> Eleven systems, one vendor — a shorter subcontractor list.</li>
        <li><strong>Zero inventory.</strong> Channel pricing for partners, no stock to carry.</li>
        <li><strong>Quoted by the plan.</strong> One package per floor plan, no monthly fee for buyers.</li>
      </ul>
    </div>
  </section>

  <!-- SCOPE TIERS -->
  <section class="tiers" data-reveal>
    <div class="tiers-inner">
      <div class="tiers-head">
        <p class="tiers-kicker">Three scopes per plan</p>
        <h2>Standardized packages, by what's included — not by price.</h2>
        <p class="tiers-sub">
          Pick a scope to fit the upgrade budget on each floor plan. Each tier is defined by which of
          the eleven systems it includes, and quoted as one package — never device by device.
        </p>
      </div>
      <div class="tier-cards">
        {tiers.map((tier) => (
          <div class="tier-card">
            <div class="tier-top">
              <h3>{tier.name}</h3>
              <span class="tier-tag">{tier.tag}</span>
            </div>
            <p class="tier-lead">{tier.lead}</p>
            <ul class="tier-list">
              {tier.systems.map((s) => (<li>{s}</li>))}
            </ul>
            <p class="tier-note">{tier.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW THE CHANNEL WORKS -->
  <section class="channel" data-reveal>
    <div class="channel-inner">
      <div class="channel-head">
        <p class="channel-kicker">How the channel works</p>
        <h2>Partner pricing, zero inventory, quoted per plan.</h2>
        <p class="channel-sub">
          Becoming a Homynex partner is built for the way builders work — no warehouse to fill, and a
          single package price you can drop into the budget.
        </p>
      </div>
      <div class="channel-steps">
        {channel.map((c) => (
          <div class="channel-step">
            <div class="channel-n">{c.n}</div>
            <h3>{c.t}</h3>
            <p>{c.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="cta" data-reveal>
    <div class="cta-card">
      <p class="cta-kicker">For builders &amp; developers</p>
      <h2>Become a Homynex partner</h2>
      <p class="cta-lead">
        Spec one smart ecosystem across every home you build — one supplier, one app, no monthly fee
        for your buyers, installed by the electrician already on site. Book a builder walkthrough and
        see how it standardizes across your next development.
      </p>
      <a href="/contact/" class="btn-primary">Become a Homynex partner</a>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ---------- shared buttons ---------- */
  .btn-primary {
    text-decoration: none; background: var(--green); color: #fff; font-weight: 600; font-size: 16px;
    padding: 16px 28px; border-radius: 999px; display: inline-block;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); background: var(--green-2); }
  .btn-ghost {
    text-decoration: none; background: rgba(255, 255, 255, 0.16); -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px); color: #fff; font-weight: 600; font-size: 16px; padding: 16px 28px;
    border-radius: 999px; border: 1px solid rgba(255, 255, 255, 0.45); display: inline-block;
    transition: background 0.2s ease;
  }
  .btn-ghost:hover { background: rgba(255, 255, 255, 0.28); }

  /* ---------- hero ---------- */
  .hero { max-width: 1320px; margin: 0 auto; padding: 28px 24px 0; }
  .hero-media {
    position: relative; border-radius: 20px; overflow: hidden;
    height: clamp(520px, 68vh, 720px);
  }
  .hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .hero-scrim {
    position: absolute; inset: 0; pointer-events: none;
    background:
      linear-gradient(180deg, rgba(15, 12, 9, 0.2) 0%, rgba(15, 12, 9, 0.1) 34%, rgba(15, 12, 9, 0.78) 100%),
      linear-gradient(90deg, rgba(15, 12, 9, 0.55) 0%, rgba(15, 12, 9, 0.12) 48%, rgba(15, 12, 9, 0) 70%);
  }
  .hero-content { position: absolute; left: 0; right: 0; bottom: 0; padding: clamp(28px, 5vw, 60px); }
  .hero-kicker {
    font: 600 13px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.16em; text-transform: uppercase;
    color: #ebd9c4; margin: 0 0 18px;
  }
  .hero-h1 {
    margin: 0; color: #fff; font-weight: 700; font-size: clamp(40px, 6.4vw, 84px);
    line-height: 0.98; letter-spacing: -0.03em; max-width: 19ch; text-shadow: 0 2px 30px rgba(0, 0, 0, 0.25);
  }
  .hero-sub { color: #f0eae0; font-size: clamp(16px, 1.5vw, 20px); line-height: 1.5; max-width: 54ch; margin: 22px 0 0; }
  .hero-sub strong { color: #fff; }
  .hero-cta-row { display: flex; gap: 14px; margin-top: 30px; flex-wrap: wrap; }
  .hero-chips {
    display: flex; gap: 10px; flex-wrap: wrap; list-style: none; margin: 26px 0 0; padding: 0;
  }
  .hero-chips li {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; color: #fff; letter-spacing: 0.02em;
    background: rgba(255, 255, 255, 0.14); border: 1px solid rgba(255, 255, 255, 0.34);
    padding: 9px 14px; border-radius: 999px; -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
  }

  /* ---------- why builders standardize ---------- */
  .why { max-width: 1240px; margin: 0 auto; padding: 80px 32px 20px; }
  .why-head { max-width: 760px; }
  .why-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 14px; }
  .why-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; max-width: 18ch; }
  .why-sub { margin: 14px 0 0; font-size: 17px; line-height: 1.55; color: var(--muted); max-width: 52ch; }
  .why-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 44px; }
  .why-card { background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 28px 26px; }
  .why-n { font: 700 15px/1 'Schibsted Grotesk', sans-serif; color: var(--terra); }
  .why-card h3 { margin: 16px 0 10px; font-weight: 600; font-size: 20px; letter-spacing: -0.01em; line-height: 1.15; }
  .why-card p { margin: 0; font-size: 14.5px; line-height: 1.55; color: var(--muted-2); }

  /* ---------- citable passage ---------- */
  .cite { max-width: 1240px; margin: 0 auto; padding: 80px 32px 20px; }
  .cite-inner { max-width: 760px; }
  .cite-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 16px; }
  .cite-text { margin: 0; font-size: clamp(18px, 2vw, 22px); line-height: 1.6; color: var(--ink); letter-spacing: -0.005em; }
  .cite-text strong { color: var(--ink); font-weight: 700; box-shadow: inset 0 -0.5em 0 rgba(30, 91, 67, 0.12); }
  .cite-points { list-style: none; margin: 28px 0 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .cite-points li { font-size: 14.5px; line-height: 1.5; color: var(--muted); border-top: 2px solid var(--green); padding-top: 12px; }
  .cite-points strong { color: var(--ink); }

  /* ---------- scope tiers ---------- */
  .tiers { background: #efeadf; border-top: 1px solid var(--line-2); border-bottom: 1px solid var(--line-2); margin-top: 60px; }
  .tiers-inner { max-width: 1240px; margin: 0 auto; padding: 84px 32px; }
  .tiers-head { max-width: 760px; }
  .tiers-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 14px; }
  .tiers-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; max-width: 22ch; }
  .tiers-sub { margin: 14px 0 0; font-size: 17px; line-height: 1.55; color: var(--muted); max-width: 54ch; }
  .tier-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 44px; }
  .tier-card { background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 30px 28px; display: flex; flex-direction: column; }
  .tier-top { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
  .tier-card h3 { margin: 0; font-weight: 700; font-size: 24px; letter-spacing: -0.01em; }
  .tier-tag { font: 600 12px/1 'Hanken Grotesk', sans-serif; color: var(--terra); letter-spacing: 0.02em; }
  .tier-lead { margin: 12px 0 0; font-size: 15px; line-height: 1.5; color: var(--muted); }
  .tier-list { list-style: none; margin: 22px 0 0; padding: 22px 0 0; border-top: 1px solid var(--line); display: flex; flex-direction: column; gap: 12px; }
  .tier-list li { position: relative; padding-left: 24px; font-size: 14.5px; line-height: 1.45; color: var(--ink-soft); font-weight: 500; }
  .tier-list li::before {
    content: ''; position: absolute; left: 0; top: 6px; width: 12px; height: 12px;
    border-radius: 50%; background: var(--green);
  }
  .tier-note { margin: 22px 0 0; font-size: 13.5px; line-height: 1.5; color: var(--muted-2); }

  /* ---------- how the channel works ---------- */
  .channel { max-width: 1240px; margin: 0 auto; padding: 84px 32px; }
  .channel-head { max-width: 760px; }
  .channel-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 14px; }
  .channel-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; max-width: 20ch; }
  .channel-sub { margin: 14px 0 0; font-size: 17px; line-height: 1.55; color: var(--muted); max-width: 54ch; }
  .channel-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 44px; }
  .channel-step { background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 28px 26px; }
  .channel-n { font: 700 15px/1 'Schibsted Grotesk', sans-serif; color: var(--terra); }
  .channel-step h3 { margin: 16px 0 10px; font-weight: 600; font-size: 19px; letter-spacing: -0.01em; line-height: 1.15; }
  .channel-step p { margin: 0; font-size: 14px; line-height: 1.55; color: var(--muted-2); }

  /* ---------- cta ---------- */
  .cta { max-width: 1240px; margin: 0 auto; padding: 20px 32px 96px; }
  .cta-card { border-radius: 20px; background: var(--dark); color: var(--on-dark); padding: clamp(48px, 6vw, 84px) 32px; text-align: center; }
  .cta-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mint); margin: 0 0 20px; }
  .cta-card h2 { margin: 0 auto; max-width: 18ch; font-weight: 700; font-size: clamp(32px, 4.6vw, 58px); line-height: 1.02; letter-spacing: -0.025em; color: #fff; }
  .cta-lead { margin: 20px auto 0; max-width: 52ch; font-size: 17px; line-height: 1.6; color: var(--on-dark-muted); }
  .cta-card .btn-primary { margin-top: 32px; }

  /* ---------- responsive ---------- */
  @media (max-width: 880px) {
    .why-cards { grid-template-columns: 1fr 1fr; }
    .cite-points { grid-template-columns: 1fr; gap: 0; }
    .cite-points li { border-top: none; border-left: 2px solid var(--green); padding: 4px 0 4px 14px; margin-bottom: 14px; }
    .tier-cards { grid-template-columns: 1fr; }
    .channel-steps { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .hero { padding: 16px 14px 0; }
    .why { padding: 56px 22px 8px; }
    .why-cards { grid-template-columns: 1fr; }
    .cite { padding: 56px 22px 8px; }
    .tiers-inner { padding: 60px 22px; }
    .channel { padding: 60px 22px; }
    .channel-steps { grid-template-columns: 1fr; }
    .cta { padding: 16px 22px 64px; }
  }
</style>
