---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const drivers = [
  {
    n: '01',
    t: 'How big the home is',
    d: 'Square footage and the number of rooms set how many switches, sensors, locks, cameras and climate zones a home needs. A larger floor plan covers more space, so its quote runs higher than a compact one.',
  },
  {
    n: '02',
    t: 'Which of the 11 systems',
    d: 'Entry, lighting, climate, security, audio, energy and the rest are modular. A home wired for every system is quoted differently from one that starts with the core few — you only pay for the systems you include.',
  },
  {
    n: '03',
    t: 'New build vs retrofit',
    d: 'Wiring a system into a home under construction is far cheaper than opening finished walls later. A new build is the lowest-cost moment to specify; a retrofit carries the added labor of working around an existing home.',
  },
  {
    n: '04',
    t: 'Scope tier',
    d: 'Essentials, Enhanced or Whole-home — the tier is defined by which systems are included, not by a per-device price list. Moving up a tier adds systems to the home, never a monthly plan.',
  },
];

const faqs = [
  {
    q: 'How much does a whole-home smart system cost?',
    a: 'A whole-home smart system is quoted per home rather than from a fixed price list, because every floor plan differs in size, room count and which systems it includes. Homynex prices it as one integrated, one-time purchase with no monthly fee, sized to sit inside a new-home upgrade budget. The cost is driven by home size, which of the eleven systems are included, whether it is a new build or a retrofit, and the scope tier. The honest answer to "how much" is a quote built around your specific home — not a number copied from a catalog.',
  },
  {
    q: 'Why don’t you list prices?',
    a: 'Because there is no single price that would be true for every home. Two houses can have the same square footage and still need very different amounts of wiring, devices and systems. Publishing a device price list would also push the decision toward a cart of gadgets bought one at a time, which is the opposite of what Homynex is — one integrated system tuned to the home. Instead of a misleading sticker price, we quote each floor plan individually so the number reflects the actual home.',
  },
  {
    q: 'Is it cheaper to install during construction?',
    a: 'Yes. Wiring a whole-home system in while the walls are open, during the build, avoids the labor and finishing cost of cutting into a finished home later. Specifying during construction is the lowest-cost moment to add automation, which is why Homynex is designed to be installed by your licensed local electrician as part of the build rather than retrofitted after move-in.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title="How Much Does a Whole-Home Smart System Cost? | Homynex"
  description="A whole-home smart system from Homynex is quoted per home — no device price list, no monthly fee. Here's how pricing works, the one-time-vs-monthly 10-year math, and what drives a quote."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Nav current="how" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-kicker">Pricing</p>
      <h1 class="hero-h1">How much does a whole-home smart system cost?</h1>
      <p class="hero-sub">
        A whole-home smart system is quoted per home, not from a price list — every floor plan is different.
        Here&rsquo;s how Homynex pricing works, the one-time-vs-monthly math over ten years, and what actually
        shapes your quote.
      </p>
      <div class="hero-cta-row">
        <a href="/contact/" class="btn-primary">Get a per-home quote</a>
        <a href="/no-monthly-fee/" class="btn-line">Why no monthly fee?</a>
      </div>
    </div>
  </section>

  <!-- CITABLE PASSAGE -->
  <section class="cite" data-reveal>
    <div class="cite-inner">
      <p class="cite-kicker">The short answer</p>
      <p class="cite-text">
        A whole-home smart system from <strong>Homynex is quoted per home</strong> because every floor plan
        differs in size, room count and which systems it includes — there is <strong>no single price</strong>.
        It is a <strong>one-time purchase with no monthly fee</strong>, sized to fit inside a new-home upgrade
        budget rather than a lifetime of recurring payments. You are buying <strong>one integrated system tuned
        to the home</strong>, not a cart of devices bought box by box. The quote is built around your specific
        home, so the honest answer to &ldquo;how much&rdquo; is a number that reflects the home in front of us —
        not a sticker price copied from a catalog. Homynex is supplied by SmartSync Electric and quoted across
        Utah&rsquo;s Wasatch Front — Lehi, Provo, Salt Lake City and St.&nbsp;George.
      </p>
      <ul class="cite-points">
        <li><strong>Quoted per home.</strong> One integrated package per floor plan, no device price list.</li>
        <li><strong>One-time, $0/month.</strong> Bought once and owned outright — no subscription.</li>
        <li><strong>Sized to the budget.</strong> Built to fit a new-home upgrade, not a monthly bill.</li>
      </ul>
    </div>
  </section>

  <!-- ONE-TIME VS MONTHLY: THE 10-YEAR MATH -->
  <section class="math" data-reveal>
    <div class="math-card">
      <p class="math-kicker">One-time vs monthly</p>
      <h2 class="math-h2">The 10-year math: a subscription never stops, a purchase does.</h2>
      <p class="math-intro">
        The clearest way to compare a one-time system with a monthly one is to run the meter forward ten years.
        The subscription figures below are <strong>illustrative only</strong> — a typical range for a
        professionally-monitored plan, not a quote from any provider.
      </p>
      <div class="math-grid">
        <div class="math-cell">
          <div class="math-tag">Subscription · illustrative</div>
          <div class="math-v">~$30&ndash;60 / mo</div>
          <p class="math-d">
            An illustrative monthly plan in the <strong>$30&ndash;60</strong> range, carried over ten years, is
            $30&ndash;60 &times; 120 months &asymp; <strong>$3,600&ndash;$7,200</strong> — and the meter keeps
            running after that.
          </p>
        </div>
        <div class="math-cell math-cell--us">
          <div class="math-tag math-tag--us">Homynex · one-time</div>
          <div class="math-v">$0 / mo after</div>
          <p class="math-d">
            Homynex is a one-time purchase quoted per home, with <strong>$0/month after</strong>. There is no
            recurring fee to total up — once it is installed, the ten-year cost of keeping it running is nothing.
          </p>
        </div>
      </div>
      <p class="math-fine">
        The <strong>$30&ndash;60/month</strong> figure is <strong>illustrative only</strong> and not a quote from
        any provider; real subscription plans vary. We do not publish a Homynex price because every home is quoted
        individually — ask for a quote for your specific floor plan.
      </p>
    </div>
  </section>

  <!-- WHY IT COSTS LESS DURING CONSTRUCTION -->
  <section class="build" data-reveal>
    <div class="build-inner">
      <div class="build-text">
        <p class="build-kicker">Timing matters</p>
        <h2>Why it costs less during construction</h2>
        <p class="build-lead">
          The cheapest moment to add a whole-home system is while the walls are still open. Wiring it in during
          the build lets your electrician run cable as part of the work already happening on site — no opening
          finished walls, no patch-and-paint, no second trade to coordinate later.
        </p>
        <p class="build-lead">
          Retrofitting the same system into a finished home means cutting in, fishing wire and making good
          afterwards — added labor that a new build simply avoids. Specify during construction and the system is
          part of the home from day one, at the lowest cost it will ever be.
        </p>
      </div>
      <ul class="build-points">
        <li>
          <span class="bp-t">During the build</span>
          <span class="bp-d">Cable runs with the open walls — no demolition, no patching, no separate trade.</span>
        </li>
        <li>
          <span class="bp-t">As a retrofit</span>
          <span class="bp-d">Walls are opened and closed again — added labor and finishing on top of the system.</span>
        </li>
        <li>
          <span class="bp-t">The takeaway</span>
          <span class="bp-d">New construction is the lowest-cost moment to specify a whole-home system.</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- WHAT SHAPES YOUR QUOTE -->
  <section class="drivers" data-reveal>
    <div class="drivers-inner">
      <div class="drivers-head">
        <p class="drivers-kicker">What shapes your quote</p>
        <h2>Four things move the number</h2>
        <p class="drivers-sub">
          Every quote is built from the same handful of inputs. None of them is a per-device price list — they
          describe the home, not a catalog.
        </p>
      </div>
      <ol class="dsteps">
        {drivers.map((s) => (
          <li class="dstep">
            <div class="dstep-n">{s.n}</div>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq" data-reveal>
    <div class="faq-inner">
      <p class="faq-kicker">Common questions</p>
      <h2 class="faq-h2">Whole-home cost, answered</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="cta" data-reveal>
    <div class="cta-card">
      <p class="cta-kicker">No price list — a real number for your home</p>
      <h2>Get a per-home quote</h2>
      <p class="cta-lead">
        Tell us your floor plan and which systems you want, and we&rsquo;ll quote one integrated whole-home
        package — installed by your licensed local electrician, owned outright, with $0/month forever.
      </p>
      <a href="/contact/" class="btn-primary">Get a per-home quote</a>
      <p class="cta-sub">
        Want the detail? See <a href="/how-it-works/" class="cta-link">how it works</a> and
        <a href="/no-monthly-fee/" class="cta-link">why there&rsquo;s no monthly fee</a>.
      </p>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ---------- shared buttons ---------- */
  .btn-primary {
    text-decoration: none; background: var(--green); color: #fff; font-weight: 600; font-size: 16px;
    padding: 16px 28px; border-radius: 999px; display: inline-block;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); background: var(--green-2); }
  .btn-line {
    text-decoration: none; color: var(--green); font-weight: 600; font-size: 16px; padding: 16px 4px;
    border-bottom: 2px solid var(--green); display: inline-block; align-self: center;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .btn-line:hover { color: var(--green-2); border-bottom-color: var(--green-2); }

  /* ---------- hero ---------- */
  .hero { max-width: 1240px; margin: 0 auto; padding: clamp(56px, 9vw, 110px) 32px clamp(20px, 4vw, 40px); }
  .hero-inner { max-width: 22ch; }
  .hero-kicker {
    font: 600 13px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--terra); margin: 0 0 18px;
  }
  .hero-h1 {
    margin: 0; color: var(--ink); font-weight: 700; font-size: clamp(40px, 6.4vw, 84px);
    line-height: 0.98; letter-spacing: -0.03em;
  }
  .hero-sub {
    color: var(--muted); font-size: clamp(16px, 1.6vw, 20px); line-height: 1.55; max-width: 56ch;
    margin: 24px 0 0;
  }
  .hero-cta-row { display: flex; gap: 20px; margin-top: 32px; flex-wrap: wrap; align-items: center; }

  /* ---------- citable passage ---------- */
  .cite { max-width: 1240px; margin: 0 auto; padding: 64px 32px 20px; }
  .cite-inner { max-width: 760px; }
  .cite-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 16px; }
  .cite-text { margin: 0; font-size: clamp(18px, 2vw, 22px); line-height: 1.6; color: var(--ink); letter-spacing: -0.005em; }
  .cite-text strong { color: var(--ink); font-weight: 700; box-shadow: inset 0 -0.5em 0 rgba(30, 91, 67, 0.12); }
  .cite-points { list-style: none; margin: 28px 0 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .cite-points li { font-size: 14.5px; line-height: 1.5; color: var(--muted); border-top: 2px solid var(--green); padding-top: 12px; }
  .cite-points strong { color: var(--ink); }

  /* ---------- one-time vs monthly: the 10-year math ---------- */
  .math { max-width: 1240px; margin: 0 auto; padding: 64px 32px 20px; }
  .math-card { background: #efeadf; border: 1px solid var(--line-2); border-radius: 20px; padding: clamp(32px, 4vw, 56px); }
  .math-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--terra); margin: 0 0 14px; }
  .math-h2 { margin: 0; font-weight: 700; font-size: clamp(26px, 3.2vw, 40px); letter-spacing: -0.02em; line-height: 1.05; max-width: 24ch; }
  .math-intro { margin: 16px 0 0; font-size: 16px; line-height: 1.6; color: var(--muted); max-width: 60ch; }
  .math-intro strong { color: var(--ink); }
  .math-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin: 28px 0 0; }
  .math-cell { background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 26px 26px 28px; }
  .math-cell--us { border-color: var(--green); box-shadow: 0 14px 34px rgba(30, 91, 67, 0.08); }
  .math-tag { font: 600 11px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted-2); }
  .math-tag--us { color: var(--green); }
  .math-v { font: 700 clamp(28px, 3.4vw, 42px)/1 'Schibsted Grotesk', sans-serif; letter-spacing: -0.02em; color: var(--ink); margin: 14px 0 0; }
  .math-d { margin: 14px 0 0; font-size: 14.5px; line-height: 1.55; color: var(--muted-2); }
  .math-d strong { color: var(--ink); }
  .math-fine { margin: 22px 0 0; font-size: 13px; line-height: 1.55; color: var(--muted); max-width: 66ch; }
  .math-fine strong { color: var(--ink); }

  /* ---------- why it costs less during construction ---------- */
  .build { max-width: 1240px; margin: 0 auto; padding: 64px 32px 20px; }
  .build-inner {
    display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(28px, 4vw, 56px); align-items: start;
  }
  .build-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 14px; }
  .build-text h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 44px); letter-spacing: -0.02em; line-height: 1.04; max-width: 16ch; }
  .build-lead { margin: 18px 0 0; font-size: 16.5px; line-height: 1.6; color: var(--muted); max-width: 52ch; }
  .build-points { list-style: none; margin: 6px 0 0; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .build-points li {
    background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 22px 24px;
    display: flex; flex-direction: column; gap: 7px;
  }
  .bp-t { font: 700 16px/1.1 'Schibsted Grotesk', sans-serif; letter-spacing: -0.01em; color: var(--ink); }
  .bp-d { font-size: 14.5px; line-height: 1.5; color: var(--muted-2); }

  /* ---------- what shapes your quote ---------- */
  .drivers { max-width: 1240px; margin: 0 auto; padding: 72px 32px 20px; }
  .drivers-head { max-width: 52ch; }
  .drivers-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--terra); margin: 0 0 14px; }
  .drivers-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; max-width: 18ch; }
  .drivers-sub { margin: 14px 0 0; font-size: 17px; line-height: 1.55; color: var(--muted); max-width: 52ch; }
  .dsteps { list-style: none; display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin: 44px 0 0; padding: 0; }
  .dstep { background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 28px 26px; }
  .dstep-n { font: 700 26px/1 'Schibsted Grotesk', sans-serif; color: var(--terra); letter-spacing: -0.02em; }
  .dstep h3 { margin: 16px 0 10px; font-weight: 600; font-size: 20px; letter-spacing: -0.01em; line-height: 1.1; }
  .dstep p { margin: 0; font-size: 14.5px; line-height: 1.55; color: var(--muted-2); }

  /* ---------- faq ---------- */
  .faq { max-width: 1240px; margin: 0 auto; padding: 64px 32px 20px; }
  .faq-inner { max-width: 820px; }
  .faq-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 14px; }
  .faq-h2 { margin: 0 0 28px; font-weight: 700; font-size: clamp(28px, 3.6vw, 44px); letter-spacing: -0.02em; line-height: 1.04; }
  .faq-list { display: grid; gap: 16px; }
  .faq-item { background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 26px 28px; }
  .faq-item h3 { margin: 0 0 10px; font-weight: 600; font-size: clamp(18px, 2vw, 22px); letter-spacing: -0.01em; color: var(--ink); }
  .faq-item p { margin: 0; font-size: 15px; line-height: 1.6; color: var(--muted-2); }

  /* ---------- cta ---------- */
  .cta { max-width: 1240px; margin: 0 auto; padding: 64px 32px 96px; }
  .cta-card { border-radius: 20px; background: var(--dark); color: var(--on-dark); padding: clamp(48px, 6vw, 84px) 32px; text-align: center; }
  .cta-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mint); margin: 0 0 20px; }
  .cta-card h2 { margin: 0 auto; max-width: 18ch; font-weight: 700; font-size: clamp(32px, 4.6vw, 58px); line-height: 1.02; letter-spacing: -0.025em; color: #fff; }
  .cta-lead { margin: 20px auto 0; max-width: 52ch; font-size: 17px; line-height: 1.6; color: var(--on-dark-muted); }
  .cta-card .btn-primary { margin-top: 32px; }
  .cta-sub { margin: 22px auto 0; font-size: 14.5px; color: var(--on-dark-muted); }
  .cta-link { color: var(--mint); font-weight: 600; text-decoration: none; border-bottom: 1px solid rgba(127, 183, 158, 0.5); padding-bottom: 2px; }
  .cta-link:hover { border-bottom-color: var(--mint); }

  /* ---------- responsive ---------- */
  @media (max-width: 880px) {
    .cite-points { grid-template-columns: 1fr; gap: 0; }
    .cite-points li { border-top: none; border-left: 2px solid var(--green); padding: 4px 0 4px 14px; margin-bottom: 14px; }
    .math-grid { grid-template-columns: 1fr; }
    .build-inner { grid-template-columns: 1fr; }
    .dsteps { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .hero { padding: 44px 22px 8px; }
    .hero-cta-row { gap: 16px; }
    .cite { padding: 48px 22px 12px; }
    .math { padding: 48px 22px 12px; }
    .build { padding: 48px 22px 12px; }
    .drivers { padding: 56px 22px 12px; }
    .dsteps { grid-template-columns: 1fr; }
    .faq { padding: 48px 22px 12px; }
    .cta { padding: 48px 22px 64px; }
  }
</style>
