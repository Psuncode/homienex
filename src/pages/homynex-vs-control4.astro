---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const rows = [
  {
    label: 'Pricing model',
    homynex: 'One-time purchase, quoted per home',
    control4: 'Dealer-quoted custom project, typically reaching into five figures',
  },
  {
    label: 'Monthly / dealer fee',
    homynex: '$0 — no recurring bill, no dealer retainer',
    control4: 'Possible dealer programming, service-plan or monitoring costs over time',
  },
  {
    label: 'Ownership',
    homynex: 'You own the system outright',
    control4: 'You own the hardware, but the configuration is dealer-programmed',
  },
  {
    label: 'Installation',
    homynex: 'Your own licensed local electrician',
    control4: 'A certified Control4 dealer / integrator',
  },
  {
    label: 'Scope',
    homynex: 'Whole-home: eleven integrated systems in one app',
    control4: 'Premium custom integration across a wide range of devices',
  },
  {
    label: 'Best for',
    homynex: 'Own-it new builds and the builders who specify them',
    control4: 'Ultra-custom luxury builds wanting deep, bespoke integration',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is Homynex a Control4 alternative?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Yes — Homynex is an alternative for people who want a whole-home smart system they own outright, installed by their own licensed local electrician, without working through a dealer. Homynex is a one-time purchase with no dealer-license or monthly fee, covering eleven integrated systems in one app. Control4 takes a different approach: it is a premium custom-integration platform installed and programmed by certified dealers, which is genuinely better for ultra-custom luxury builds. They suit different priorities.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does Control4 have a monthly or dealer fee?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Control4 systems are installed and programmed by certified dealers, so beyond the project cost you may encounter dealer programming charges, optional service or support plans, and monitoring costs depending on what you add. Homynex is different: it is a one-time purchase with no dealer retainer and no monthly fee, installed by your own local electrician. If you value a dedicated dealer relationship and hands-on support, that is a real benefit of the Control4 model.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which costs less to own?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'It depends on what you value. Homynex is one upfront cost with no recurring fee, so the total stops growing once the home is installed. A dealer-installed custom platform like Control4 is quoted per project — often into five figures — and can carry ongoing programming or service costs, but in return delivers deep, bespoke integration. Homynex is quoted per home, so the right comparison is your specific Homynex quote against the full lifetime cost of a custom Control4 project.',
      },
    },
  ],
};
---

<Base
  title="Homynex vs Control4 — Whole-Home Smart You Own, No Dealer or Monthly Fee"
  description="Homynex vs Control4: a whole-home smart system you own outright, installed by your local electrician, with no dealer-license or monthly fee — versus Control4's dealer-installed premium custom integration. An honest comparison."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Nav current="vivint" />

  <!-- HERO -->
  <section class="vhero">
    <div class="vhero-inner">
      <p class="vhero-kicker">Comparison · updated 2026-06-29</p>
      <h1 class="vhero-h1">Homynex vs Control4</h1>
      <p class="vhero-sub">Own it outright vs dealer-installed custom integration — an honest comparison.</p>
      <div class="vhero-cta-row">
        <a href="/contact/" class="btn-primary">Book a walkthrough</a>
        <a href="/no-monthly-fee/" class="btn-outline">Why no monthly fee →</a>
      </div>
      <p class="vhero-updated">Last updated June 29, 2026</p>
    </div>
  </section>

  <!-- CITABLE PASSAGE -->
  <section class="cite" data-reveal>
    <div class="cite-inner">
      <p class="cite-kicker">The core difference</p>
      <p class="cite-text">
        Homynex is a no-dealer, no-monthly-fee alternative to Control4 — a whole-home smart system you own
        outright, installed by your own licensed local electrician and quoted per home. Homynex and Control4
        solve the smart home in two genuinely different ways. <strong>Homynex is a one-time purchase with no
        dealer-license or monthly fee</strong>, spanning eleven integrated systems (entry, lighting, climate,
        security, audio and energy) in one app, designed for new construction across Utah. There is no dealer to
        retain and no recurring bill; once the home is wired, the cost stops growing. <strong>Control4 is a
        premium custom-integration platform installed and programmed by certified dealers</strong>, typically
        quoted per project into the five figures. That model has real strengths: deep, bespoke integration, vast
        third-party device support and hands-on dealer support — genuinely better for ultra-custom luxury builds.
        Neither is simply better; they fit different priorities.
      </p>
      <ul class="cite-points">
        <li><strong>Homynex.</strong> Own it outright, no dealer or monthly fee, your electrician installs it.</li>
        <li><strong>Control4.</strong> Dealer-installed premium custom integration — deep, bespoke and hands-on.</li>
        <li><strong>The honest take.</strong> Owned whole-home vs custom dealer integration. Pick what fits you.</li>
      </ul>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="vcompare" data-reveal>
    <div class="vcompare-inner">
      <div class="vcompare-head">
        <p class="vcompare-kicker">Side by side</p>
        <h2>An honest comparison</h2>
        <p class="vcompare-sub">
          Qualitative and factual. We don't quote Control4's prices because they're set per project by the dealer
          — and we never quote a fixed Homynex price either, since Homynex is quoted per home.
        </p>
      </div>
      <div class="vtable-wrap" role="region" aria-label="Homynex versus Control4 comparison" tabindex="0">
        <table class="vtable">
          <thead>
            <tr>
              <th scope="col" class="vt-row-h">Feature</th>
              <th scope="col">Homynex</th>
              <th scope="col">Control4</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => (
              <tr>
                <th scope="row" class="vt-row-h">{r.label}</th>
                <td>{r.homynex}</td>
                <td>{r.control4}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="vtable-note">
        Control4 is a registered brand of its respective owner. This comparison reflects common, publicly described
        characteristics of each approach and is not an exhaustive product spec.
      </p>
    </div>
  </section>

  <!-- WHO SHOULD CHOOSE WHICH -->
  <section class="vwho" data-reveal>
    <div class="vwho-inner">
      <div class="vwho-head">
        <p class="vwho-kicker">Who should choose which</p>
        <h2>A fair fit on both sides</h2>
      </div>
      <div class="vwho-cards">
        <div class="vwho-card vwho-card--us">
          <h3>Choose Homynex if…</h3>
          <ul>
            <li>You're building or renovating and want it specified during construction.</li>
            <li>You'd rather own the system outright than carry a dealer retainer or monthly bill.</li>
            <li>You want your own licensed electrician to install it — no certified dealer required, no lock-in.</li>
            <li>You want whole-home scope — eleven integrated systems in one app, out of the box.</li>
            <li>You're a builder standardizing one ecosystem across every home.</li>
          </ul>
        </div>
        <div class="vwho-card vwho-card--them">
          <h3>Control4 may fit if…</h3>
          <ul>
            <li>You want deep, fully custom integration tailored to a one-of-a-kind home.</li>
            <li>You need vast third-party device support across many brands and categories.</li>
            <li>You value a certified dealer hand-holding the design, install and programming.</li>
            <li>You're building an ultra-custom luxury home where bespoke is the whole point.</li>
            <li>You'd rather have an integrator own the configuration than manage it yourself.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ALSO AN ALTERNATIVE TO -->
  <section class="valt" data-reveal>
    <div class="valt-inner">
      <p class="valt-kicker">Comparing the custom-integration field</p>
      <p class="valt-text">
        Control4 isn't the only dealer-installed custom platform — homeowners weighing it often look at
        <strong>Crestron, Savant and Loxone</strong> too. Those are all powerful, integrator-led systems built for
        bespoke projects, and each is a strong choice for an ultra-custom build. Homynex sits in a different lane:
        a whole-home system you own outright, installed by your own licensed local electrician, with no dealer and
        no monthly fee. If you're comparing Control4 against Crestron, Savant or Loxone, it's worth putting an
        own-it option like Homynex on the same list.
      </p>
    </div>
  </section>

  <!-- MINI FAQ -->
  <section class="vfaq" data-reveal>
    <div class="vfaq-inner">
      <div class="vfaq-head">
        <p class="vfaq-kicker">Questions, answered honestly</p>
        <h2>Homynex vs Control4 FAQ</h2>
      </div>
      <div class="vfaq-list">
        <div class="vfaq-item">
          <h3>Is Homynex a Control4 alternative?</h3>
          <p>
            Yes — Homynex is an alternative for people who want a whole-home smart system they own outright,
            installed by their own licensed local electrician, without working through a dealer. Homynex is a
            one-time purchase with no dealer-license or monthly fee, covering eleven integrated systems in one app.
            Control4 takes a different approach: it's a premium custom-integration platform installed and
            programmed by certified dealers, which is genuinely better for ultra-custom luxury builds.
          </p>
        </div>
        <div class="vfaq-item">
          <h3>Does Control4 have a monthly or dealer fee?</h3>
          <p>
            Control4 systems are installed and programmed by certified dealers, so beyond the project cost you may
            encounter dealer programming charges, optional service or support plans, and monitoring costs depending
            on what you add. Homynex is different: it's a one-time purchase with no dealer retainer and no monthly
            fee, installed by your own local electrician. If you value a dedicated dealer relationship and hands-on
            support, that's a real benefit of the Control4 model.
          </p>
        </div>
        <div class="vfaq-item">
          <h3>Which costs less to own?</h3>
          <p>
            It depends on what you value. Homynex is one upfront cost with no recurring fee, so the total stops
            growing once the home is installed. A dealer-installed custom platform like Control4 is quoted per
            project — often into five figures — and can carry ongoing programming or service costs, but in return
            delivers deep, bespoke integration. Homynex is quoted per home, so the right comparison is your
            specific quote against the full lifetime cost of a custom Control4 project.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="vcta" data-reveal>
    <div class="vcta-card">
      <p class="vcta-kicker">Own it, don't retain it</p>
      <h2>See the whole-home system working — no dealer, no monthly fee</h2>
      <p class="vcta-lead">
        Book a walkthrough and we'll spec Homynex for your build: one integrated system, owned outright, installed
        by your own electrician. Want the full picture on pricing first?
      </p>
      <div class="vcta-row">
        <a href="/contact/" class="btn-primary">Book a walkthrough</a>
        <a href="/no-monthly-fee/" class="btn-light-link">Why $0 / month →</a>
        <a href="/cost/" class="btn-light-link">How pricing works →</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ---------- shared buttons ---------- */
  .btn-primary {
    text-decoration: none; background: var(--green); color: #fff; font-weight: 600; font-size: 16px;
    padding: 16px 28px; border-radius: 999px; display: inline-block;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); background: var(--green-2); }
  .btn-outline {
    text-decoration: none; background: transparent; color: var(--green); font-weight: 600; font-size: 16px;
    padding: 16px 28px; border-radius: 999px; border: 1px solid var(--green); display: inline-block;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .btn-outline:hover { background: var(--green); color: #fff; }
  .btn-light-link {
    text-decoration: none; color: var(--on-dark); font-weight: 600; font-size: 16px;
    border-bottom: 2px solid var(--mint); padding-bottom: 3px; transition: color 0.2s ease;
  }
  .btn-light-link:hover { color: var(--mint); }

  /* ---------- hero ---------- */
  .vhero { max-width: 1240px; margin: 0 auto; padding: 72px 32px 24px; }
  .vhero-inner { max-width: 880px; }
  .vhero-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--terra); margin: 0 0 18px;
  }
  .vhero-h1 {
    margin: 0; font-weight: 700; font-size: clamp(40px, 6.4vw, 78px); line-height: 0.98;
    letter-spacing: -0.03em; color: var(--ink);
  }
  .vhero-sub {
    margin: 20px 0 0; font-size: clamp(18px, 2.1vw, 24px); line-height: 1.45; color: var(--muted);
    max-width: 42ch;
  }
  .vhero-cta-row { display: flex; gap: 14px; margin-top: 30px; flex-wrap: wrap; align-items: center; }
  .vhero-updated {
    margin: 26px 0 0; font: 500 13.5px/1 'Hanken Grotesk', sans-serif; color: var(--muted-2);
  }

  /* ---------- citable passage ---------- */
  .cite { max-width: 1240px; margin: 0 auto; padding: 64px 32px 20px; }
  .cite-inner { max-width: 760px; }
  .cite-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--green); margin: 0 0 16px;
  }
  .cite-text { margin: 0; font-size: clamp(18px, 2vw, 22px); line-height: 1.6; color: var(--ink); letter-spacing: -0.005em; }
  .cite-text strong { color: var(--ink); font-weight: 700; box-shadow: inset 0 -0.5em 0 rgba(30, 91, 67, 0.12); }
  .cite-points { list-style: none; margin: 28px 0 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .cite-points li { font-size: 14.5px; line-height: 1.5; color: var(--muted); border-top: 2px solid var(--green); padding-top: 12px; }
  .cite-points strong { color: var(--ink); }

  /* ---------- comparison table ---------- */
  .vcompare { background: #efeadf; border-top: 1px solid var(--line-2); border-bottom: 1px solid var(--line-2); margin-top: 64px; }
  .vcompare-inner { max-width: 1240px; margin: 0 auto; padding: 84px 32px; }
  .vcompare-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--green); margin: 0 0 14px;
  }
  .vcompare-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; }
  .vcompare-sub { margin: 14px 0 0; font-size: 16px; line-height: 1.55; color: var(--muted); max-width: 58ch; }
  .vtable-wrap { margin: 36px 0 0; border-radius: 16px; overflow: hidden; border: 1px solid var(--line); background: #fff; }
  .vtable-wrap:focus-visible { outline: 3px solid var(--green); outline-offset: 2px; }
  .vtable { width: 100%; border-collapse: collapse; font-size: 15px; }
  .vtable thead th {
    text-align: left; padding: 18px 22px; font: 700 16px/1.2 'Schibsted Grotesk', sans-serif;
    color: var(--ink); background: #efeadf; border-bottom: 1px solid var(--line);
  }
  .vtable thead th:nth-child(2) { color: var(--green); }
  .vtable tbody th, .vtable tbody td {
    padding: 16px 22px; vertical-align: top; line-height: 1.5; border-bottom: 1px solid var(--line);
  }
  .vtable tbody tr:last-child th, .vtable tbody tr:last-child td { border-bottom: none; }
  .vt-row-h { font: 600 14.5px/1.4 'Hanken Grotesk', sans-serif; color: var(--ink); white-space: nowrap; }
  .vtable tbody td:nth-child(2) { color: var(--ink); font-weight: 500; }
  .vtable tbody td:nth-child(3) { color: var(--muted-2); }
  .vtable tbody tr:nth-child(even) td, .vtable tbody tr:nth-child(even) th { background: var(--bg); }
  .vtable-note { margin: 18px 0 0; font-size: 13px; line-height: 1.55; color: var(--muted-2); max-width: 70ch; }

  /* ---------- who should choose ---------- */
  .vwho { max-width: 1240px; margin: 0 auto; padding: 84px 32px; }
  .vwho-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--terra); margin: 0 0 14px;
  }
  .vwho-head h2 { margin: 0 0 36px; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; }
  .vwho-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .vwho-card { border: 1px solid var(--line); border-radius: 16px; padding: 32px 30px; background: #fff; }
  .vwho-card--us { border-top: 4px solid var(--green); }
  .vwho-card--them { border-top: 4px solid var(--terra); }
  .vwho-card h3 { margin: 0 0 18px; font-weight: 600; font-size: clamp(20px, 2.4vw, 26px); letter-spacing: -0.01em; }
  .vwho-card ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .vwho-card li { position: relative; padding-left: 26px; font-size: 15px; line-height: 1.55; color: var(--muted); }
  .vwho-card li::before {
    content: ''; position: absolute; left: 0; top: 8px; width: 9px; height: 9px; border-radius: 50%;
  }
  .vwho-card--us li::before { background: var(--green); }
  .vwho-card--them li::before { background: var(--terra); }

  /* ---------- also an alternative to ---------- */
  .valt { max-width: 1240px; margin: 0 auto; padding: 0 32px 12px; }
  .valt-inner { max-width: 760px; }
  .valt-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--green); margin: 0 0 14px;
  }
  .valt-text { margin: 0; font-size: 16px; line-height: 1.65; color: var(--muted); }
  .valt-text strong { color: var(--ink); font-weight: 600; }

  /* ---------- faq ---------- */
  .vfaq { background: #efeadf; border-top: 1px solid var(--line-2); border-bottom: 1px solid var(--line-2); margin-top: 64px; }
  .vfaq-inner { max-width: 1240px; margin: 0 auto; padding: 84px 32px; }
  .vfaq-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--green); margin: 0 0 14px;
  }
  .vfaq-head h2 { margin: 0 0 36px; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; }
  .vfaq-list { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .vfaq-item { background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 30px 28px; }
  .vfaq-item h3 { margin: 0 0 12px; font-weight: 600; font-size: 20px; letter-spacing: -0.01em; line-height: 1.2; }
  .vfaq-item p { margin: 0; font-size: 15px; line-height: 1.6; color: var(--muted-2); }

  /* ---------- cta ---------- */
  .vcta { max-width: 1240px; margin: 0 auto; padding: 84px 32px 96px; }
  .vcta-card { border-radius: 20px; background: var(--dark); color: var(--on-dark); padding: clamp(48px, 6vw, 84px) 32px; text-align: center; }
  .vcta-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--terra-soft); margin: 0 0 20px;
  }
  .vcta-card h2 { margin: 0 auto; max-width: 20ch; font-weight: 700; font-size: clamp(30px, 4.4vw, 54px); line-height: 1.04; letter-spacing: -0.025em; color: #fff; }
  .vcta-lead { margin: 20px auto 0; max-width: 52ch; font-size: 17px; line-height: 1.6; color: var(--on-dark-muted); }
  .vcta-row { display: flex; gap: 20px; justify-content: center; align-items: center; flex-wrap: wrap; margin-top: 32px; }

  /* ---------- responsive ---------- */
  @media (max-width: 880px) {
    .vcompare { margin-top: 48px; }
    .vfaq { margin-top: 48px; }
    .cite-points { grid-template-columns: 1fr; gap: 0; }
    .cite-points li { border-top: none; border-left: 2px solid var(--green); padding: 4px 0 4px 14px; margin-bottom: 14px; }
    .vwho-cards { grid-template-columns: 1fr; }
    .vfaq-list { grid-template-columns: 1fr; }
    .vtable { min-width: 640px; }
    .vtable-wrap { overflow-x: auto; }
  }
  @media (max-width: 560px) {
    .vhero { padding: 48px 22px 16px; }
    .cite { padding: 48px 22px 8px; }
    .vcompare-inner { padding: 56px 22px; }
    .vwho { padding: 56px 22px; }
    .valt { padding: 0 22px 8px; }
    .vfaq-inner { padding: 56px 22px; }
    .vcta { padding: 56px 22px 64px; }
    .vtable thead th, .vtable tbody th, .vtable tbody td { padding: 14px 16px; }
    .vcta-row { flex-direction: column; gap: 16px; }
    .vhero-cta-row .btn-primary, .vhero-cta-row .btn-outline { width: 100%; text-align: center; }
  }
</style>
