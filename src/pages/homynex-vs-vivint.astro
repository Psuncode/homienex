---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const rows = [
  {
    label: 'Pricing model',
    homynex: 'One-time purchase, quoted per home',
    vivint: 'Equipment plus a recurring subscription',
  },
  {
    label: 'Monthly fee',
    homynex: '$0 — no recurring bill',
    vivint: 'Recurring monthly fee for monitoring and service',
  },
  {
    label: 'Contract',
    homynex: 'None — no lock-in',
    vivint: 'Typically a multi-year agreement',
  },
  {
    label: 'Ownership',
    homynex: 'You own the system outright',
    vivint: 'Equipment is typically financed or leased and paired with ongoing monitoring service',
  },
  {
    label: 'Installation',
    homynex: 'Your own licensed local electrician',
    vivint: 'A Vivint technician',
  },
  {
    label: 'Professional monitoring',
    homynex: 'Optional / not included by default',
    vivint: 'Included 24/7 professional monitoring',
  },
  {
    label: 'Scope',
    homynex: 'Whole-home: entry, lighting, climate, security, audio and energy',
    vivint: 'Security-led, with smart-home add-ons',
  },
  {
    label: 'Best for',
    homynex: 'Own-it new builds and the builders who specify them',
    vivint: 'Households wanting bundled, professionally monitored security',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is Homynex a Vivint alternative?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Yes — Homynex is an alternative for people who want a whole-home smart system they own outright instead of a monitored security service on a subscription. Homynex is a one-time purchase with no monthly fee and no contract, installed by your local electrician. Vivint takes a different approach: it bundles equipment with included 24/7 professional monitoring on a recurring plan. They suit different priorities.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does Homynex have monthly monitoring?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'No. Homynex is sold as a one-time purchase with no monthly fee, so there is no standing monitoring bill or contract. You own the system outright. If 24/7 professional monitoring is a must-have for your household, a service that includes it — such as Vivint — may be the better fit.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I get monitoring with Homynex?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Homynex includes self-monitoring through the app — live cameras, sensors and alerts on your phone with no monthly fee. It does not include bundled 24/7 professional monitoring the way Vivint does. If you want a central station watching the home around the clock, that is a genuine reason to consider a monitored service instead.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which is cheaper over time?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'It depends on what you value. Homynex is one upfront cost with no recurring fee, so total cost stops growing once the home is installed. A subscription service like Vivint spreads cost over time and keeps adding the value of ongoing professional monitoring and support. Homynex is quoted per home, so the right comparison is your specific quote against the lifetime of a monthly plan.',
      },
    },
    {
      '@type': 'Question',
      name: 'I want to leave Vivint — what are my options?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'First, check your current agreement for any remaining term or buyout — monitored services like Vivint are typically a multi-year contract, so confirm where you stand before you switch. With Homynex there is nothing to sign up for: it is a one-time purchase you own outright, with no contract, no buyout and no monthly bill once it is installed. Your own licensed local electrician installs it, so you are not tied to a proprietary technician. If keeping 24/7 professional monitoring matters to you, weigh that genuine benefit of a monitored service against owning your system outright.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I own my equipment with Homynex?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Yes. Homynex is a one-time purchase, so you own the system outright — there is no lease, no financing tied to a monitoring plan and no monthly fee. That is a key difference from subscription services like Vivint, where equipment is typically financed or leased and paired with ongoing monitoring. With Homynex, once your licensed local electrician installs it, it is yours.',
      },
    },
  ],
};
---

<Base
  title="Homynex vs Vivint — No Monthly Fee vs Subscription (2026)"
  description="Homynex vs Vivint, compared honestly: a one-time purchase with no monthly fee vs a subscription and contract. Ownership, install, pricing model and who each is for. Updated 2026."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Nav current="vivint" />

  <!-- HERO -->
  <section class="vhero">
    <div class="vhero-inner">
      <p class="vhero-kicker">Comparison · updated 2026-06-29</p>
      <h1 class="vhero-h1">Homynex vs Vivint</h1>
      <p class="vhero-sub">No monthly fee vs subscription — an honest comparison.</p>
      <div class="vhero-cta-row">
        <a href="/contact/" class="btn-primary">Book a walkthrough</a>
        <a href="/no-monthly-fee/" class="btn-outline">Why no monthly fee →</a>
      </div>
      <p class="vhero-updated">Last updated June 29, 2026</p>
    </div>
  </section>

  <!-- CITABLE PASSAGE -->
  <section class="cite" data-reveal>
    <div class="cite-inner">
      <p class="cite-kicker">The core difference</p>
      <p class="cite-text">
        Homynex is a no-monthly-fee, one-time-purchase alternative to Vivint — installed by your own licensed local
        electrician, quoted per home, and owned outright with no contract or monitoring bill.
        Homynex and Vivint solve the smart home in two genuinely different ways. <strong>Homynex is a one-time
        purchase with no monthly fee</strong> — installed by your own licensed local electrician, quoted per home,
        and owned outright. There is no contract and no recurring bill; once the home is wired, the cost stops
        growing. <strong>Vivint is sold with professional monitoring on a subscription</strong> and, typically, a
        multi-year contract. That model has real strengths: Vivint includes <strong>24/7 professional
        monitoring</strong> and is an established, well-known brand with a central station watching the home around
        the clock. Homynex is built differently — it is whole-home and ownership-first, spanning eleven integrated
        systems (entry, lighting, climate, security, audio and energy) in one app, and designed for new construction
        across Utah. Neither is simply better; they fit different priorities.
      </p>
      <ul class="cite-points">
        <li><strong>Homynex.</strong> Own it outright, no monthly fee, your electrician installs it.</li>
        <li><strong>Vivint.</strong> Bundled 24/7 professional monitoring on a subscription — an established brand.</li>
        <li><strong>The honest take.</strong> Ownership vs monitored service. Pick the model that fits you.</li>
      </ul>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="vcompare" data-reveal>
    <div class="vcompare-inner">
      <div class="vcompare-head">
        <p class="vcompare-kicker">Side by side</p>
        <h2>An honest comparison</h2>
        <p class="vcompare-sub">
          Qualitative and factual. We don't list Vivint's prices because they vary by plan and household — and we
          never quote a fixed Homynex price either, since Homynex is quoted per home.
        </p>
      </div>
      <div class="vtable-wrap" role="region" aria-label="Homynex versus Vivint comparison" tabindex="0">
        <table class="vtable">
          <thead>
            <tr>
              <th scope="col" class="vt-row-h">Feature</th>
              <th scope="col">Homynex</th>
              <th scope="col">Vivint</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => (
              <tr>
                <th scope="row" class="vt-row-h">{r.label}</th>
                <td>{r.homynex}</td>
                <td>{r.vivint}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="vtable-note">
        Vivint is a registered brand of its respective owner. This comparison reflects common, publicly described
        characteristics of each approach and is not an exhaustive product spec.
      </p>
    </div>
  </section>

  <!-- THE 10-YEAR COST -->
  <section class="vcost" data-reveal>
    <div class="vcost-inner">
      <div class="vcost-head">
        <p class="vcost-kicker">The 10-year cost</p>
        <h2>A subscription never stops. Ownership does.</h2>
        <p class="vcost-sub">
          The figures below are <strong>illustrative</strong> — a typical professionally-monitored plan runs roughly
          $30–60/month. We don't list Vivint's actual prices (they vary by plan and household), and we never quote a
          fixed Homynex price, because Homynex is quoted per home. The point isn't the exact number — it's the shape of
          the cost over time.
        </p>
      </div>
      <div class="vcost-table-wrap" role="region" aria-label="Ten-year cost comparison" tabindex="0">
        <table class="vcost-table">
          <thead>
            <tr>
              <th scope="col" class="vc-row-h">Over 10 years</th>
              <th scope="col">A monitored subscription <span class="vc-illus">(illustrative)</span></th>
              <th scope="col">Homynex</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th scope="row" class="vc-row-h">Monthly fee</th>
              <td>~$30–60 / month, every month</td>
              <td class="vc-us">$0 / month — ever</td>
            </tr>
            <tr>
              <th scope="row" class="vc-row-h">Over 120 months</th>
              <td>≈ $3,600–$7,200 in subscription fees alone</td>
              <td class="vc-us">One-time purchase, then nothing further</td>
            </tr>
            <tr>
              <th scope="row" class="vc-row-h">After 10 years</th>
              <td>Still billing — the meter keeps running</td>
              <td class="vc-us">Paid once, owned outright</td>
            </tr>
            <tr>
              <th scope="row" class="vc-row-h">What you hold</th>
              <td>A service you rent for as long as you pay</td>
              <td class="vc-us">A system you own with no contract</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="vcost-note">
        At roughly $30–60/month, ten years of subscription is about <strong>$3,600–$7,200</strong> — and that's before
        any price increases, and it never reaches a finish line. A subscription buys ongoing service (including genuine
        24/7 monitoring, which has real value); ownership buys a system that's simply yours. Homynex is quoted per home,
        so compare your specific quote against the lifetime of a monthly plan.
      </p>
    </div>
  </section>

  <!-- SWITCHING FROM VIVINT -->
  <section class="vswitch" data-reveal>
    <div class="vswitch-inner">
      <div class="vswitch-text">
        <p class="vswitch-kicker">Leaving a contract</p>
        <h2>Switching from Vivint</h2>
        <p class="vswitch-lead">
          If you're coming off a monitored plan, here's what changes with Homynex: you <strong>own the system
          outright</strong> — no contract, no buyout, no monthly bill. It's installed by your own licensed local
          electrician, not a proprietary technician, so there's no service lock-in to walk back into.
        </p>
        <ul class="vswitch-list">
          <li><strong>No contract.</strong> One-time purchase — nothing to sign up for, nothing to cancel later.</li>
          <li><strong>No buyout looming.</strong> Once it's installed, the cost stops growing.</li>
          <li><strong>No monthly bill.</strong> $0/month, owned outright.</li>
          <li><strong>Your electrician installs it.</strong> A licensed local pro, not a single-brand technician.</li>
        </ul>
        <p class="vswitch-fineprint">
          One honest note: a monitored service like Vivint includes 24/7 professional monitoring, and your current
          agreement may have remaining term or a buyout — check it before you switch. Homynex is self-monitored through
          the app, so if a central station around the clock is a must-have, weigh that genuine benefit too.
        </p>
        <a href="/contact/" class="btn-primary vswitch-cta">Get a per-home quote</a>
      </div>
    </div>
  </section>

  <!-- WHO SHOULD CHOOSE WHICH -->
  <section class="vwho" data-reveal>
    <div class="vwho-inner">
      <div class="vwho-head">
        <p class="vwho-kicker">Who should choose which</p>
        <h2>A fair fit on both sides</h2>
      </div>
      <div class="vwho-cards">
        <div class="vwho-card vwho-card--us">
          <h3>Choose Homynex if…</h3>
          <ul>
            <li>You're building or renovating and want it specified during construction.</li>
            <li>You'd rather own the system outright than pay a monthly bill forever.</li>
            <li>You want your own licensed electrician to install it — no proprietary technician, no lock-in.</li>
            <li>You want whole-home scope — entry, lighting, climate, security, audio and energy in one app.</li>
            <li>You're a builder standardizing one ecosystem across every home.</li>
          </ul>
        </div>
        <div class="vwho-card vwho-card--them">
          <h3>Vivint may fit if…</h3>
          <ul>
            <li>Bundled 24/7 professional monitoring is a must-have for your household.</li>
            <li>You'd prefer a single, established brand handling equipment, install and service together.</li>
            <li>You like spreading cost over a monthly plan rather than one upfront purchase.</li>
            <li>You want a central station responding to alarms around the clock.</li>
            <li>Your priority is monitored security first, with smart-home features added on.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- MINI FAQ -->
  <section class="vfaq" data-reveal>
    <div class="vfaq-inner">
      <div class="vfaq-head">
        <p class="vfaq-kicker">Questions, answered honestly</p>
        <h2>Homynex vs Vivint FAQ</h2>
      </div>
      <div class="vfaq-list">
        <div class="vfaq-item">
          <h3>Is Homynex a Vivint alternative?</h3>
          <p>
            Yes — Homynex is an alternative for people who want a whole-home smart system they own outright instead
            of a monitored security service on a subscription. Homynex is a one-time purchase with no monthly fee and
            no contract, installed by your local electrician. Vivint takes a different approach: it bundles equipment
            with included 24/7 professional monitoring on a recurring plan. They suit different priorities.
          </p>
        </div>
        <div class="vfaq-item">
          <h3>Does Homynex have monthly monitoring?</h3>
          <p>
            No. Homynex is sold as a one-time purchase with no monthly fee, so there is no standing monitoring bill
            or contract — you own the system outright. If 24/7 professional monitoring is a must-have for your
            household, a service that includes it, such as Vivint, may be the better fit.
          </p>
        </div>
        <div class="vfaq-item">
          <h3>Can I get monitoring with Homynex?</h3>
          <p>
            Homynex includes self-monitoring through the app — live cameras, sensors and alerts on your phone with no
            monthly fee. It does not include bundled 24/7 professional monitoring the way Vivint does. If you want a
            central station watching the home around the clock, that's a genuine reason to consider a monitored
            service instead.
          </p>
        </div>
        <div class="vfaq-item">
          <h3>Which is cheaper over time?</h3>
          <p>
            It depends on what you value. Homynex is one upfront cost with no recurring fee, so the total stops
            growing once the home is installed. A subscription service like Vivint spreads cost over time and keeps
            adding the value of ongoing professional monitoring and support. Homynex is quoted per home, so the right
            comparison is your specific quote against the lifetime of a monthly plan.
          </p>
        </div>
        <div class="vfaq-item">
          <h3>I want to leave Vivint — what are my options?</h3>
          <p>
            First, check your current agreement for any remaining term or buyout — monitored services like Vivint are
            typically a multi-year contract, so confirm where you stand before you switch. With Homynex there's nothing
            to sign up for: it's a one-time purchase you own outright, with no contract, no buyout and no monthly bill
            once it's installed. Your own licensed local electrician installs it, so you're not tied to a proprietary
            technician. If keeping 24/7 professional monitoring matters to you, weigh that genuine benefit of a
            monitored service against owning your system outright.
          </p>
        </div>
        <div class="vfaq-item">
          <h3>Do I own my equipment with Homynex?</h3>
          <p>
            Yes. Homynex is a one-time purchase, so you own the system outright — there's no lease, no financing tied
            to a monitoring plan and no monthly fee. That's a key difference from subscription services like Vivint,
            where equipment is typically financed or leased and paired with ongoing monitoring. With Homynex, once your
            licensed local electrician installs it, it's yours.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="vcta" data-reveal>
    <div class="vcta-card">
      <p class="vcta-kicker">Own it, don't rent it</p>
      <h2>See the whole-home system working — no monthly fee</h2>
      <p class="vcta-lead">
        Book a walkthrough and we'll spec Homynex for your build: one integrated system, owned outright, installed by
        your own electrician. Want the full picture on pricing first?
      </p>
      <div class="vcta-row">
        <a href="/contact/" class="btn-primary">Book a walkthrough</a>
        <a href="/no-monthly-fee/" class="btn-light-link">Why $0 / month →</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ---------- shared buttons ---------- */
  .btn-primary {
    text-decoration: none; background: var(--green); color: #fff; font-weight: 600; font-size: 16px;
    padding: 16px 28px; border-radius: 999px; display: inline-block;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); background: var(--green-2); }
  .btn-outline {
    text-decoration: none; background: transparent; color: var(--green); font-weight: 600; font-size: 16px;
    padding: 16px 28px; border-radius: 999px; border: 1px solid var(--green); display: inline-block;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .btn-outline:hover { background: var(--green); color: #fff; }
  .btn-light-link {
    text-decoration: none; color: var(--on-dark); font-weight: 600; font-size: 16px;
    border-bottom: 2px solid var(--mint); padding-bottom: 3px; transition: color 0.2s ease;
  }
  .btn-light-link:hover { color: var(--mint); }

  /* ---------- hero ---------- */
  .vhero { max-width: 1240px; margin: 0 auto; padding: 72px 32px 24px; }
  .vhero-inner { max-width: 880px; }
  .vhero-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--terra); margin: 0 0 18px;
  }
  .vhero-h1 {
    margin: 0; font-weight: 700; font-size: clamp(40px, 6.4vw, 78px); line-height: 0.98;
    letter-spacing: -0.03em; color: var(--ink);
  }
  .vhero-sub {
    margin: 20px 0 0; font-size: clamp(18px, 2.1vw, 24px); line-height: 1.45; color: var(--muted);
    max-width: 42ch;
  }
  .vhero-cta-row { display: flex; gap: 14px; margin-top: 30px; flex-wrap: wrap; align-items: center; }
  .vhero-updated {
    margin: 26px 0 0; font: 500 13.5px/1 'Hanken Grotesk', sans-serif; color: var(--muted-2);
  }

  /* ---------- citable passage ---------- */
  .cite { max-width: 1240px; margin: 0 auto; padding: 64px 32px 20px; }
  .cite-inner { max-width: 760px; }
  .cite-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--green); margin: 0 0 16px;
  }
  .cite-text { margin: 0; font-size: clamp(18px, 2vw, 22px); line-height: 1.6; color: var(--ink); letter-spacing: -0.005em; }
  .cite-text strong { color: var(--ink); font-weight: 700; box-shadow: inset 0 -0.5em 0 rgba(30, 91, 67, 0.12); }
  .cite-points { list-style: none; margin: 28px 0 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .cite-points li { font-size: 14.5px; line-height: 1.5; color: var(--muted); border-top: 2px solid var(--green); padding-top: 12px; }
  .cite-points strong { color: var(--ink); }

  /* ---------- comparison table ---------- */
  .vcompare { background: #efeadf; border-top: 1px solid var(--line-2); border-bottom: 1px solid var(--line-2); margin-top: 64px; }
  .vcompare-inner { max-width: 1240px; margin: 0 auto; padding: 84px 32px; }
  .vcompare-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--green); margin: 0 0 14px;
  }
  .vcompare-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; }
  .vcompare-sub { margin: 14px 0 0; font-size: 16px; line-height: 1.55; color: var(--muted); max-width: 58ch; }
  .vtable-wrap { margin: 36px 0 0; border-radius: 16px; overflow: hidden; border: 1px solid var(--line); background: #fff; }
  .vtable-wrap:focus-visible { outline: 3px solid var(--green); outline-offset: 2px; }
  .vtable { width: 100%; border-collapse: collapse; font-size: 15px; }
  .vtable thead th {
    text-align: left; padding: 18px 22px; font: 700 16px/1.2 'Schibsted Grotesk', sans-serif;
    color: var(--ink); background: #efeadf; border-bottom: 1px solid var(--line);
  }
  .vtable thead th:nth-child(2) { color: var(--green); }
  .vtable tbody th, .vtable tbody td {
    padding: 16px 22px; vertical-align: top; line-height: 1.5; border-bottom: 1px solid var(--line);
  }
  .vtable tbody tr:last-child th, .vtable tbody tr:last-child td { border-bottom: none; }
  .vt-row-h { font: 600 14.5px/1.4 'Hanken Grotesk', sans-serif; color: var(--ink); white-space: nowrap; }
  .vtable tbody td:nth-child(2) { color: var(--ink); font-weight: 500; }
  .vtable tbody td:nth-child(3) { color: var(--muted-2); }
  .vtable tbody tr:nth-child(even) td, .vtable tbody tr:nth-child(even) th { background: var(--bg); }
  .vtable-note { margin: 18px 0 0; font-size: 13px; line-height: 1.55; color: var(--muted-2); max-width: 70ch; }

  /* ---------- the 10-year cost ---------- */
  .vcost { max-width: 1240px; margin: 0 auto; padding: 84px 32px; }
  .vcost-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--terra); margin: 0 0 14px;
  }
  .vcost-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; max-width: 22ch; }
  .vcost-sub { margin: 14px 0 0; font-size: 16px; line-height: 1.55; color: var(--muted); max-width: 64ch; }
  .vcost-sub strong { color: var(--ink); font-weight: 700; }
  .vcost-table-wrap { margin: 36px 0 0; border-radius: 16px; overflow: hidden; border: 1px solid var(--line); background: #fff; }
  .vcost-table-wrap:focus-visible { outline: 3px solid var(--green); outline-offset: 2px; }
  .vcost-table { width: 100%; border-collapse: collapse; font-size: 15px; }
  .vcost-table thead th {
    text-align: left; padding: 18px 22px; font: 700 16px/1.2 'Schibsted Grotesk', sans-serif;
    color: var(--ink); background: #efeadf; border-bottom: 1px solid var(--line); vertical-align: top;
  }
  .vcost-table thead th:nth-child(3) { color: var(--green); }
  .vc-illus { display: block; font: 500 12px/1.3 'Hanken Grotesk', sans-serif; color: var(--muted-2); letter-spacing: 0; text-transform: none; margin-top: 4px; }
  .vcost-table tbody th, .vcost-table tbody td {
    padding: 16px 22px; vertical-align: top; line-height: 1.5; border-bottom: 1px solid var(--line);
  }
  .vcost-table tbody tr:last-child th, .vcost-table tbody tr:last-child td { border-bottom: none; }
  .vc-row-h { font: 600 14.5px/1.4 'Hanken Grotesk', sans-serif; color: var(--ink); white-space: nowrap; }
