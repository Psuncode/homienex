---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const steps = [
  {
    n: '01',
    t: 'We walk your plans',
    d: 'We sit down with your floor plan and walk the home room by room — entry, lighting, climate, security, audio and energy — to see which systems each space needs before a single device is chosen.',
  },
  {
    n: '02',
    t: 'We spec the whole home',
    d: 'One integrated package — Essentials, Enhanced or Whole-home scope — designed around the build and your budget, not a cart of individual gadgets bought one at a time.',
  },
  {
    n: '03',
    t: 'Your electrician installs it',
    d: 'Your own licensed local electrician installs the system during construction or renovation. No proprietary technician, no service lock-in, no separate trade to coordinate.',
  },
  {
    n: '04',
    t: 'One app, owned outright',
    d: 'You hand over a home that runs on one app — lighting, locks, cameras, climate and energy in one place. Owned outright, with no contract and no monthly fee, ever.',
  },
];

const tiers = [
  {
    n: 'Essentials',
    t: 'The smart foundation',
    d: 'The core that makes a home feel smart from day one.',
    systems: ['Entry & access', 'Lighting & power', 'Comfort & climate', 'One-app control'],
  },
  {
    n: 'Enhanced',
    t: 'Comfort, secured',
    d: 'Everything in Essentials, with a fuller security and comfort layer.',
    systems: ['All Essentials systems', 'Security & cameras', 'Sensors & detection', 'Multi-room audio'],
  },
  {
    n: 'Whole-home',
    t: 'Every system, integrated',
    d: 'The complete eleven-system package — the home running as one.',
    systems: ['All Enhanced systems', 'Energy, solar & storage', 'EV charging', 'Family sharing & scenes'],
  },
];

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How Homynex is specified and installed',
  description:
    'Homynex is a whole-home smart system bought once with no monthly fee, installed by your licensed local electrician and quoted as one whole-home package per floor plan.',
  totalTime: 'P1D',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'We walk your plans',
      text: 'We review the floor plan room by room to see which of the systems each home needs — entry, lighting, climate, security, audio and energy.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'We spec the whole home',
      text: 'We spec one integrated package — Essentials, Enhanced or Whole-home scope — tuned to the build and the budget, not a cart of individual devices.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Your licensed electrician installs it',
      text: 'Your own licensed local electrician installs the system during construction or renovation — no proprietary technician and no service lock-in.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Hand over a home that runs on one app',
      text: 'The home is handed over running on one app, owned outright, with no contract and no monthly fee.',
    },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Whole-home smart system installation',
  description:
    'A whole-home smart system installed by your licensed local electrician, sold as a one-time purchase with no monthly fee and quoted as one whole-home package per home.',
  serviceType: 'Whole-home smart system installation',
  provider: {
    '@type': 'Organization',
    name: 'Homynex',
    url: 'https://homynex.com',
  },
  areaServed: { '@type': 'State', name: 'Utah' },
  offers: {
    '@type': 'Offer',
    priceSpecification: { '@type': 'PriceSpecification', priceCurrency: 'USD' },
    availability: 'https://schema.org/InStock',
  },
};
---

<Base
  title="How Homynex Works — Buyout, Local Install & Per-Home Pricing"
  description="How Homynex works: one whole-home smart package, quoted per home, installed by your licensed local electrician. A one-time purchase with no monthly fee — the process and how pricing works."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <Nav current="how" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-kicker">How it works</p>
      <h1 class="hero-h1">One system. One quote. No monthly fee.</h1>
      <p class="hero-sub">
        Homynex is a whole-home smart system, bought once and installed by your own licensed electrician
        during the build. Here&rsquo;s how we spec it, how it gets installed, and why it&rsquo;s quoted by the
        home instead of by the device.
      </p>
      <div class="hero-cta-row">
        <a href="/contact/" class="btn-primary">Get a quote for your development</a>
        <a href="/no-monthly-fee/" class="btn-line">Why no monthly fee?</a>
      </div>
    </div>
  </section>

  <!-- CITABLE PASSAGE -->
  <section class="cite" data-reveal>
    <div class="cite-inner">
      <p class="cite-kicker">The Homynex model</p>
      <p class="cite-text">
        Homynex is a whole-home smart system — lighting, locks, cameras, sensors, climate, audio and energy in
        one app — <strong>bought once, with no monthly fee</strong>. It is installed by a licensed local
        electrician during construction or renovation, and quoted as
        <strong>one whole-home package per floor plan</strong> — never priced device by device. Unlike a
        subscription system such as Vivint, there is <strong>no contract and no monitoring bill</strong>; the
        homeowner owns the system outright. Because the quote is built around the home rather than a cart of
        gadgets, it fits inside a typical new-home upgrade budget instead of a lifetime of monthly payments.
        Homynex is supplied by SmartSync Electric and serves Utah&rsquo;s Wasatch Front — Lehi, Provo, Salt Lake
        City and St.&nbsp;George — through a network of builders, electricians and designers.
      </p>
      <ul class="cite-points">
        <li><strong>Bought once.</strong> Owned outright — no contract, no monitoring bill.</li>
        <li><strong>Your electrician installs it.</strong> During the build, with no service lock-in.</li>
        <li><strong>Quoted by the home.</strong> One package per floor plan, inside the budget.</li>
      </ul>
    </div>
  </section>

  <!-- THE PROCESS -->
  <section class="process" data-reveal>
    <div class="process-inner">
      <div class="process-head">
        <p class="process-kicker">The process</p>
        <h2>From floor plan to a home that runs itself</h2>
        <p class="process-sub">
          Four steps, one supplier. We spec it, your electrician installs it, and the home is handed over running
          on a single app.
        </p>
      </div>
      <ol class="psteps">
        {steps.map((s) => (
          <li class="pstep">
            <div class="pstep-n">{s.n}</div>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- HOW PRICING WORKS -->
  <section class="pricing" data-reveal>
    <div class="pricing-inner">
      <div class="pricing-head">
        <p class="pricing-kicker">How pricing works</p>
        <h2>One quote per home. No device price list, no monthly bill.</h2>
        <p class="pricing-sub">
          We quote by the home, not by the box — because the value is the integrated system, not the parts. One
          one-time price that sits inside your build or upgrade budget, and <strong>$0/month forever</strong>.
        </p>
      </div>
      <div class="tiers">
        {tiers.map((tier) => (
          <div class="tier">
            <div class="tier-n">{tier.n}</div>
            <h3>{tier.t}</h3>
            <p class="tier-d">{tier.d}</p>
            <ul class="tier-list">
              {tier.systems.map((sys) => (<li>{sys}</li>))}
            </ul>
            <div class="tier-note">Scope, not a price</div>
          </div>
        ))}
      </div>
      <p class="pricing-foot">
        Each tier is defined by <strong>which systems are included</strong> — never by a per-device price list.
        Move up a tier to add systems, not to unlock a monthly plan.
      </p>
    </div>
  </section>

  <!-- OWN IT CALLOUT -->
  <section class="own" data-reveal>
    <div class="own-card">
      <div class="own-text">
        <p class="own-kicker">Own it, don&rsquo;t rent it</p>
        <h2>A system you own beats a bill you never stop paying.</h2>
        <p class="own-lead">
          A subscription home keeps charging for as long as you live there. A Homynex home is bought once and
          owned outright — no contract, no monitoring bill, no lock-in. See the difference for yourself.
        </p>
      </div>
      <div class="own-links">
        <a href="/homynex-vs-vivint/" class="own-link">
          <span class="own-link-t">Homynex vs Vivint</span>
          <span class="own-link-d">Buyout versus subscription, side by side →</span>
        </a>
        <a href="/no-monthly-fee/" class="own-link">
          <span class="own-link-t">No monthly fee</span>
          <span class="own-link-d">What &ldquo;$0/month forever&rdquo; really means →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="cta" data-reveal>
    <div class="cta-card">
      <p class="cta-kicker">For builders &amp; developers</p>
      <h2>Get a quote for your development</h2>
      <p class="cta-lead">
        Tell us about the homes you&rsquo;re building and we&rsquo;ll spec one whole-home package per floor plan —
        installed by your electrician, owned outright, with no monthly fee.
      </p>
      <a href="/contact/" class="btn-primary">Get a quote for your development</a>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ---------- shared buttons ---------- */
  .btn-primary {
    text-decoration: none; background: var(--green); color: #fff; font-weight: 600; font-size: 16px;
    padding: 16px 28px; border-radius: 999px; display: inline-block;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); background: var(--green-2); }
  .btn-line {
    text-decoration: none; color: var(--green); font-weight: 600; font-size: 16px; padding: 16px 4px;
    border-bottom: 2px solid var(--green); display: inline-block; align-self: center;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .btn-line:hover { color: var(--green-2); border-bottom-color: var(--green-2); }

  /* ---------- hero ---------- */
  .hero { max-width: 1240px; margin: 0 auto; padding: clamp(56px, 9vw, 110px) 32px clamp(20px, 4vw, 40px); }
  .hero-inner { max-width: 22ch; }
  .hero-kicker {
    font: 600 13px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--terra); margin: 0 0 18px;
  }
  .hero-h1 {
    margin: 0; color: var(--ink); font-weight: 700; font-size: clamp(40px, 6.4vw, 84px);
    line-height: 0.98; letter-spacing: -0.03em;
  }
  .hero-sub {
    color: var(--muted); font-size: clamp(16px, 1.6vw, 20px); line-height: 1.55; max-width: 56ch;
    margin: 24px 0 0;
  }
  .hero-cta-row { display: flex; gap: 20px; margin-top: 32px; flex-wrap: wrap; align-items: center; }

  /* ---------- citable passage ---------- */
  .cite { max-width: 1240px; margin: 0 auto; padding: 64px 32px 20px; }
  .cite-inner { max-width: 760px; }
  .cite-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 16px; }
  .cite-text { margin: 0; font-size: clamp(18px, 2vw, 22px); line-height: 1.6; color: var(--ink); letter-spacing: -0.005em; }
  .cite-text strong { color: var(--ink); font-weight: 700; box-shadow: inset 0 -0.5em 0 rgba(30, 91, 67, 0.12); }
  .cite-points { list-style: none; margin: 28px 0 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .cite-points li { font-size: 14.5px; line-height: 1.5; color: var(--muted); border-top: 2px solid var(--green); padding-top: 12px; }
  .cite-points strong { color: var(--ink); }

  /* ---------- process ---------- */
  .process { max-width: 1240px; margin: 0 auto; padding: 72px 32px 0; }
  .process-head { max-width: 52ch; }
  .process-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--terra); margin: 0 0 14px; }
  .process-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; max-width: 18ch; }
  .process-sub { margin: 14px 0 0; font-size: 17px; line-height: 1.55; color: var(--muted); max-width: 50ch; }
  .psteps { list-style: none; display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin: 44px 0 0; padding: 0; }
  .pstep { background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 28px 26px; }
  .pstep-n { font: 700 26px/1 'Schibsted Grotesk', sans-serif; color: var(--terra); letter-spacing: -0.02em; }
  .pstep h3 { margin: 16px 0 10px; font-weight: 600; font-size: 20px; letter-spacing: -0.01em; line-height: 1.1; }
  .pstep p { margin: 0; font-size: 14.5px; line-height: 1.55; color: var(--muted-2); }

  /* ---------- pricing ---------- */
  .pricing { margin-top: 80px; background: #efeadf; border-top: 1px solid var(--line-2); border-bottom: 1px solid var(--line-2); }
  .pricing-inner { max-width: 1240px; margin: 0 auto; padding: 84px 32px; }
  .pricing-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 14px; }
  .pricing-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; max-width: 20ch; }
  .pricing-sub { margin: 14px 0 0; font-size: 17px; line-height: 1.55; color: var(--muted); max-width: 56ch; }
  .pricing-sub strong { color: var(--ink); font-weight: 700; }
  .tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 44px 0 0; }
  .tier { background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 30px 28px; display: flex; flex-direction: column; }
  .tier-n { font: 700 15px/1 'Schibsted Grotesk', sans-serif; color: var(--terra); letter-spacing: 0.04em; text-transform: uppercase; }
  .tier h3 { margin: 14px 0 8px; font-weight: 700; font-size: 24px; letter-spacing: -0.015em; line-height: 1.05; }
  .tier-d { margin: 0 0 20px; font-size: 14.5px; line-height: 1.5; color: var(--muted-2); }
  .tier-list { list-style: none; margin: 0; padding: 20px 0 0; border-top: 1px solid var(--line); display: flex; flex-direction: column; gap: 12px; }
  .tier-list li { position: relative; padding-left: 24px; font-size: 15px; line-height: 1.4; color: var(--ink-soft); font-weight: 500; }
  .tier-list li::before {
    content: ''; position: absolute; left: 0; top: 6px; width: 8px; height: 8px;
    border-radius: 999px; background: var(--green);
  }
  .tier-note { margin-top: auto; padding-top: 22px; font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted-2); }
  .pricing-foot { margin: 36px 0 0; font-size: 15px; line-height: 1.6; color: var(--muted); max-width: 60ch; }
  .pricing-foot strong { color: var(--ink); }

  /* ---------- own it callout ---------- */
  .own { max-width: 1240px; margin: 0 auto; padding: 88px 32px; }
  .own-card {
    border-radius: 20px; background: var(--green); color: #fff;
    display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(28px, 4vw, 56px);
    padding: clamp(36px, 4.5vw, 60px);
  }
  .own-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: #9fcfb8; margin: 0 0 18px; }
  .own-text h2 { margin: 0; font-weight: 700; font-size: clamp(26px, 3.2vw, 40px); line-height: 1.06; letter-spacing: -0.02em; max-width: 18ch; }
  .own-lead { margin: 18px 0 0; font-size: 16px; line-height: 1.6; color: #d6e7de; max-width: 44ch; }
  .own-links { display: flex; flex-direction: column; gap: 14px; justify-content: center; }
  .own-link {
    text-decoration: none; color: #fff; background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.22); border-radius: 14px; padding: 20px 22px;
    display: flex; flex-direction: column; gap: 6px; transition: background 0.2s ease, transform 0.2s ease;
  }
  .own-link:hover { background: rgba(255, 255, 255, 0.16); transform: translateY(-2px); }
  .own-link-t { font: 700 19px/1.1 'Schibsted Grotesk', sans-serif; letter-spacing: -0.01em; }
  .own-link-d { font-size: 14px; line-height: 1.4; color: #cfe3d9; }

  /* ---------- cta ---------- */
  .cta { max-width: 1240px; margin: 0 auto; padding: 0 32px 96px; }
  .cta-card { border-radius: 20px; background: var(--dark); color: var(--on-dark); padding: clamp(48px, 6vw, 84px) 32px; text-align: center; }
  .cta-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mint); margin: 0 0 20px; }
  .cta-card h2 { margin: 0 auto; max-width: 18ch; font-weight: 700; font-size: clamp(32px, 4.6vw, 58px); line-height: 1.02; letter-spacing: -0.025em; color: #fff; }
  .cta-lead { margin: 20px auto 0; max-width: 52ch; font-size: 17px; line-height: 1.6; color: var(--on-dark-muted); }
  .cta-card .btn-primary { margin-top: 32px; }

  /* ---------- responsive ---------- */
  @media (max-width: 880px) {
    .cite-points { grid-template-columns: 1fr; gap: 0; }
    .cite-points li { border-top: none; border-left: 2px solid var(--green); padding: 4px 0 4px 14px; margin-bottom: 14px; }
    .psteps { grid-template-columns: 1fr 1fr; }
    .tiers { grid-template-columns: 1fr; }
    .own-card { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .hero { padding: 44px 22px 8px; }
    .hero-cta-row { gap: 16px; }
    .cite { padding: 48px 22px 8px; }
    .process { padding: 56px 22px 0; }
    .psteps { grid-template-columns: 1fr; }
    .pricing-inner { padding: 60px 22px; }
    .own { padding: 64px 16px; }
    .own-card { padding: 32px 22px; }
    .cta { padding: 0 22px 64px; }
  }
</style>
