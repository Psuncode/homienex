---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RoomExplorer from '../components/RoomExplorer.astro';
import { systems } from '../data/systems.js';

const partners = ['Alexa', 'Google', 'Tuya', 'Zigbee', 'Matter'];
const stats = [
  { v: '11', l: 'integrated systems, one supplier' },
  { v: '1', l: 'app for the whole home' },
  { v: '$0', l: 'monthly fees, ever' },
  { v: '2-yr', l: 'parts & labor warranty' },
];
const steps = [
  { n: '01', t: 'We walk your plans', d: 'We review the floor plan and which of the eleven systems each home needs — entry, lighting, climate, security, audio and energy.' },
  { n: '02', t: 'We spec the whole home', d: 'One integrated package — Essentials, Enhanced or Whole-home scope — tuned to the build, not a cart of individual gadgets.' },
  { n: '03', t: 'One quote that fits the budget', d: 'A single, one-time price that sits inside your upgrade budget. No itemized devices, no monthly fee — ever.' },
];
const appFeatures = [
  { t: 'Multi-home management', d: 'All your homes, one account.' },
  { t: 'Room-based control', d: 'Devices grouped by room.' },
  { t: 'Scenes', d: 'One-touch presets.' },
  { t: 'Family sharing & calls', d: 'Share access; answer the door.' },
];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Homynex',
  url: 'https://homynex.com',
  description:
    'Homynex is a whole-home smart system sold as a one-time purchase with no monthly fee, installed by licensed local electricians, and quoted as one whole-home package per home.',
  parentOrganization: { '@type': 'Organization', name: 'SmartSync Electric Ltd' },
  areaServed: { '@type': 'State', name: 'Utah' },
  knowsAbout: ['whole-home automation', 'smart home with no monthly fee', 'smart home for builders', 'Vivint alternative'],
};
---

<Base
  title="Homynex | Whole-Home Smart System, No Monthly Fee"
  description="Homynex is a whole-home smart system — eleven integrated systems in one app, installed by your local electrician. A one-time purchase with no monthly fee, for Utah builders and homeowners."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </Fragment>

  <Nav current="home" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-media">
      <img
        src="/catalog_images/p51_1.jpg"
        alt="Modern living room at dusk with integrated Homynex lighting, climate and shades"
        class="hero-img"
        fetchpriority="high"
        decoding="async"
        width="1320"
        height="720"
      />
      <div class="hero-scrim" aria-hidden="true"></div>
    </div>
    <div class="hero-content">
      <p class="hero-kicker">For Utah builders &amp; property developers</p>
      <h1 class="hero-h1">Specify one smart ecosystem across every home you build</h1>
      <div class="hero-cta-row">
        <a href="/contact/" class="btn-primary">Book an integration walkthrough</a>
        <a href="/systems/" class="btn-ghost">Explore the 11 systems</a>
      </div>
      <ul class="hero-chips">
        <li>One-time purchase</li>
        <li>$0 / month — ever</li>
        <li>Installed by your electrician</li>
      </ul>
    </div>
  </section>

  <!-- TRUST -->
  <section class="trust">
    <div class="trust-inner">
      <span class="trust-label">Works with</span>
      {partners.map((p) => (<span class="trust-item">{p}</span>))}
    </div>
  </section>

  <!-- CITABLE PASSAGE -->
  <section class="cite" data-reveal>
    <div class="cite-inner">
      <p class="cite-kicker">What Homynex is</p>
      <p class="cite-text">
        Homynex is a whole-home smart system — lighting, locks, cameras, sensors, climate, audio and energy
        in a single app — sold as a <strong>one-time purchase with no monthly fee</strong>. Unlike subscription
        systems such as Vivint, Homynex has no contract and no recurring monitoring bill; the homeowner owns the
        system outright. It is installed by a licensed local electrician during construction or renovation, and
        quoted as <strong>one whole-home package per floor plan</strong> — never itemized device by device — so it
        fits inside a typical new-home upgrade budget instead of a lifetime of monthly payments. Homynex is
        supplied by SmartSync Electric and offered across Utah's Wasatch Front — Lehi, Provo, Salt Lake City and
        St.&nbsp;George — through a network of builders, electricians and designers. It works with Amazon Alexa and
        spans eleven integrated systems controlled from one app.
      </p>
      <ul class="cite-points">
        <li><strong>No monthly fee.</strong> Bought once, owned outright — no contract, no monitoring bill.</li>
        <li><strong>Your electrician installs it.</strong> No proprietary technician, no service lock-in.</li>
        <li><strong>Quoted by the home.</strong> One integrated package per floor plan, inside the build budget.</li>
      </ul>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats" data-reveal>
    <div class="stats-inner">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat-v">{s.v}</div>
          <div class="stat-l">{s.l}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ROOM EXPLORER -->
  <RoomExplorer />

  <!-- SYSTEMS GRID -->
  <section class="sysgrid" data-reveal>
    <div class="sysgrid-head">
      <h2>The systems</h2>
      <a href="/systems/" class="sysgrid-all">View all systems →</a>
    </div>
    <div class="sys-cards">
      {systems.map((c) => (
        <a href={c.href} class="sys-card">
          <img src={c.img} alt={`${c.name} — ${c.tag}`} class="sys-img" loading="lazy" decoding="async" width="400" height="150" />
          <div class="sys-body">
            <div class="sys-meta">
              <span class="sys-n">{c.n}</span>
              <span class="sys-count">{c.products.length} products</span>
            </div>
            <h3>{c.name}</h3>
            <p>{c.desc}</p>
            <div class="sys-tag">{c.tag} →</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- HOW PRICING WORKS -->
  <section class="pricing" data-reveal>
    <div class="pricing-inner">
      <div class="pricing-head">
        <p class="pricing-kicker">How pricing works</p>
        <h2>One quote per home. No device price list, no monthly bill.</h2>
        <p class="pricing-sub">
          We quote by the home, not by the box — because the value is the integrated system, not the parts.
        </p>
      </div>
      <div class="psteps">
        {steps.map((s) => (
          <div class="pstep">
            <div class="pstep-n">{s.n}</div>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </div>
        ))}
      </div>
      <a href="/contact/" class="btn-primary pricing-cta">Get a quote for your development</a>
    </div>
  </section>

  <!-- ENERGY TEASER -->
  <section class="energy" data-reveal>
    <div class="energy-card">
      <div class="energy-text">
        <p class="energy-kicker">Energy &amp; sustainability</p>
        <h2>Powered for independence</h2>
        <p class="energy-lead">Solar, storage and EV charging — less grid, less carbon, all in one app.</p>
        <div class="energy-stats">
          <div><div class="es-v">99.9%</div><div class="es-l">MPPT efficiency</div></div>
          <div><div class="es-v">8500+</div><div class="es-l">battery cycles</div></div>
        </div>
        <a href="/energy/" class="btn-light">Explore energy →</a>
      </div>
      <img src="/catalog_images/p47_0.jpg" alt="Home battery wall and solar storage" class="energy-img" loading="lazy" decoding="async" />
    </div>
  </section>

  <!-- APP TEASER -->
  <section class="appsec" data-reveal>
    <div class="app-card">
      <div class="app-text">
        <p class="app-kicker">The Homynex App · powered by Tuya</p>
        <h2>Every device, one screen</h2>
        <p class="app-lead">Residents manage their whole home from a single app, so you hand over a development that just works.</p>
        <div class="app-feats">
          {appFeatures.map((a) => (
            <div class="app-feat">
              <div class="af-t">{a.t}</div>
              <div class="af-d">{a.d}</div>
            </div>
          ))}
        </div>
        <div class="app-badges">
          <span class="badge">
            <svg width="17" height="20" viewBox="0 0 384 512" fill="#fff" aria-hidden="true"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C73.3 141.2 18 184.6 18 273c0 26.1 4.8 53.1 14.4 80.9 12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.1zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
            <span class="badge-txt"><small>Download on the</small><strong>App Store</strong></span>
          </span>
          <span class="badge">
            <svg width="16" height="18" viewBox="0 0 24 24" aria-hidden="true"><path fill="#34A853" d="M3.6 2.1 13 11.5 3.6 21z" opacity=".9"/><path fill="#FBBC04" d="m16.4 8.3 3.2 1.8c1 .6 1 1.9 0 2.5l-3.2 1.8L13 12.6z"/><path fill="#EA4335" d="M3.6 2.1 13 7.4l-3.4 3.4z"/><path fill="#4285F4" d="M3.6 21 13 15.7l-3.4-3.4z"/></svg>
            <span class="badge-txt"><small>Get it on</small><strong>Google Play</strong></span>
          </span>
        </div>
      </div>
      <img src="/catalog_images/p19_0.jpg" alt="The Homynex app controlling devices room by room" class="app-img" loading="lazy" decoding="async" />
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="cta" data-reveal>
    <div class="cta-card">
      <p class="cta-kicker">For builders &amp; developers</p>
      <h2>Come see the full ecosystem working together</h2>
      <p class="cta-lead">Book a guided walkthrough of every integrated system, and learn how to specify Homynex across your next development — one supplier, one app, no monthly fee.</p>
      <a href="/contact/" class="btn-primary">Book your walkthrough</a>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ---------- shared buttons ---------- */
  .btn-primary {
    text-decoration: none; background: var(--green); color: #fff; font-weight: 600; font-size: 16px;
    padding: 16px 28px; border-radius: 999px; display: inline-block;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); background: var(--green-2); }
  .btn-ghost {
    text-decoration: none; background: rgba(255, 255, 255, 0.16); -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px); color: #fff; font-weight: 600; font-size: 16px; padding: 16px 28px;
    border-radius: 999px; border: 1px solid rgba(255, 255, 255, 0.45); display: inline-block;
    transition: background 0.2s ease;
  }
  .btn-ghost:hover { background: rgba(255, 255, 255, 0.28); }
  .btn-light {
    text-decoration: none; background: #fff; color: var(--green); font-weight: 600; font-size: 15px;
    padding: 15px 26px; border-radius: 999px; display: inline-block; align-self: flex-start;
    transition: transform 0.2s ease;
  }
  .btn-light:hover { transform: translateY(-2px); }

  /* ---------- hero ---------- */
  .hero { max-width: 1320px; margin: 0 auto; padding: 28px 24px 0; }
  .hero-media {
    position: relative; border-radius: 20px; overflow: hidden;
    height: clamp(520px, 68vh, 720px);
  }
  .hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .hero-scrim {
    position: absolute; inset: 0; pointer-events: none;
    background:
      linear-gradient(180deg, rgba(15, 12, 9, 0.30) 0%, rgba(15, 12, 9, 0.14) 26%, rgba(15, 12, 9, 0.60) 70%, rgba(15, 12, 9, 0.90) 100%),
      linear-gradient(90deg, rgba(15, 12, 9, 0.72) 0%, rgba(15, 12, 9, 0.32) 46%, rgba(15, 12, 9, 0) 78%);
  }
  .hero-content { position: absolute; left: 0; right: 0; bottom: 0; padding: clamp(28px, 5vw, 60px); }
  .hero-kicker {
    font: 700 13px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.16em; text-transform: uppercase;
    color: #f3e3cf; margin: 0 0 16px; text-shadow: 0 1px 14px rgba(0, 0, 0, 0.55);
  }
  .hero-h1 {
    margin: 0; color: #fff; font-weight: 700; font-size: clamp(40px, 6.4vw, 84px);
    line-height: 0.98; letter-spacing: -0.03em; max-width: 19ch;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45), 0 1px 3px rgba(0, 0, 0, 0.40);
  }
  .hero-sub { color: #f0eae0; font-size: clamp(16px, 1.5vw, 20px); line-height: 1.5; max-width: 54ch; margin: 22px 0 0; }
  .hero-sub strong { color: #fff; }
  .hero-cta-row { display: flex; gap: 14px; margin-top: 30px; flex-wrap: wrap; }
  .hero-chips {
    display: flex; gap: 10px; flex-wrap: wrap; list-style: none; margin: 26px 0 0; padding: 0;
  }
  .hero-chips li {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; color: #fff; letter-spacing: 0.02em;
    background: rgba(255, 255, 255, 0.14); border: 1px solid rgba(255, 255, 255, 0.34);
    padding: 9px 14px; border-radius: 999px; -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
  }

  /* ---------- trust ---------- */
  .trust { background: #efeadf; border-top: 1px solid var(--line-2); border-bottom: 1px solid var(--line-2); margin-top: 30px; }
  .trust-inner {
    max-width: 1240px; margin: 0 auto; padding: 20px 32px; display: flex; align-items: center;
    justify-content: center; gap: 16px 38px; flex-wrap: wrap;
  }
  .trust-label { font: 600 11px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); }
  .trust-item { font: 600 18px/1 'Schibsted Grotesk', sans-serif; color: var(--ink-soft); letter-spacing: 0.01em; }

  /* ---------- citable passage ---------- */
  .cite { max-width: 1240px; margin: 0 auto; padding: 80px 32px 20px; }
  .cite-inner { max-width: 760px; }
  .cite-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 16px; }
  .cite-text { margin: 0; font-size: clamp(18px, 2vw, 22px); line-height: 1.6; color: var(--ink); letter-spacing: -0.005em; }
  .cite-text strong { color: var(--ink); font-weight: 700; box-shadow: inset 0 -0.5em 0 rgba(30, 91, 67, 0.12); }
  .cite-points { list-style: none; margin: 28px 0 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .cite-points li { font-size: 14.5px; line-height: 1.5; color: var(--muted); border-top: 2px solid var(--green); padding-top: 12px; }
  .cite-points strong { color: var(--ink); }

  /* ---------- stats ---------- */
  .stats { max-width: 1240px; margin: 0 auto; padding: 40px 32px 20px; }
  .stats-inner { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; border-top: 1px solid #e2dcd0; padding-top: 36px; }
  .stat-v { font: 700 clamp(34px, 4vw, 52px)/1 'Schibsted Grotesk', sans-serif; letter-spacing: -0.02em; color: var(--ink); }
  .stat-l { font-size: 14px; color: var(--muted); margin-top: 10px; font-weight: 500; }

  /* ---------- systems grid ---------- */
  .sysgrid { max-width: 1240px; margin: 0 auto; padding: 56px 32px 88px; }
  .sysgrid-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 30px; flex-wrap: wrap; }
  .sysgrid-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.4vw, 40px); letter-spacing: -0.02em; }
  .sysgrid-all { text-decoration: none; font-weight: 600; font-size: 15px; color: var(--green); border-bottom: 2px solid var(--green); padding-bottom: 3px; }
  .sys-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .sys-card {
    display: block; text-decoration: none; color: inherit; background: #fff; border: 1px solid var(--line);
    border-radius: 16px; overflow: hidden; transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .sys-card:hover { transform: translateY(-6px); border-color: var(--green); box-shadow: 0 18px 40px rgba(22, 20, 18, 0.1); }
  .sys-img { width: 100%; height: 150px; object-fit: cover; background: #ece7dd; }
  .sys-body { padding: 20px 22px 22px; }
  .sys-meta { display: flex; align-items: baseline; justify-content: space-between; }
  .sys-n { font: 700 15px/1 'Schibsted Grotesk', sans-serif; color: var(--terra); }
  .sys-count { font-size: 12px; color: var(--muted-2); font-weight: 500; }
  .sys-body h3 { margin: 13px 0 8px; font-weight: 600; font-size: 21px; letter-spacing: -0.01em; line-height: 1.1; }
  .sys-body p { margin: 0; font-size: 14px; line-height: 1.5; color: var(--muted-2); }
  .sys-tag { margin-top: 16px; font-weight: 600; font-size: 14px; color: var(--green); }

  /* ---------- pricing ---------- */
  .pricing { background: #efeadf; border-top: 1px solid var(--line-2); border-bottom: 1px solid var(--line-2); }
  .pricing-inner { max-width: 1240px; margin: 0 auto; padding: 84px 32px; }
  .pricing-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 14px; }
  .pricing-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; max-width: 20ch; }
  .pricing-sub { margin: 14px 0 0; font-size: 17px; line-height: 1.55; color: var(--muted); max-width: 52ch; }
  .psteps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 44px 0 0; }
  .pstep { background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 28px 26px; }
  .pstep-n { font: 700 15px/1 'Schibsted Grotesk', sans-serif; color: var(--terra); }
  .pstep h3 { margin: 16px 0 10px; font-weight: 600; font-size: 20px; letter-spacing: -0.01em; }
  .pstep p { margin: 0; font-size: 14.5px; line-height: 1.55; color: var(--muted-2); }
  .pricing-cta { margin-top: 36px; }

  /* ---------- energy ---------- */
  .energy { max-width: 1320px; margin: 0 auto; padding: 88px 24px; }
  .energy-card { border-radius: 20px; overflow: hidden; background: var(--green); color: #fff; display: grid; grid-template-columns: 1fr 1fr; }
  .energy-text { padding: clamp(36px, 4.5vw, 64px); display: flex; flex-direction: column; justify-content: center; }
  .energy-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: #9fcfb8; margin: 0 0 18px; }
  .energy-text h2 { margin: 0; font-weight: 700; font-size: clamp(30px, 3.8vw, 48px); line-height: 1.04; letter-spacing: -0.02em; }
  .energy-lead { margin: 18px 0 0; font-size: 16.5px; line-height: 1.6; color: #d6e7de; max-width: 42ch; }
  .energy-stats { display: flex; gap: 32px; margin: 30px 0 32px; }
  .es-v { font: 700 34px/1 'Schibsted Grotesk', sans-serif; }
  .es-l { font-size: 13px; color: #9fcfb8; margin-top: 5px; }
  .energy-img { width: 100%; height: 100%; min-height: 380px; object-fit: cover; }

  /* ---------- app ---------- */
  .appsec { max-width: 1240px; margin: 0 auto; padding: 0 32px 96px; }
  .app-card { background: #fff; border: 1px solid var(--line); border-radius: 20px; overflow: hidden; display: grid; grid-template-columns: 1fr 360px; align-items: stretch; }
  .app-text { padding: clamp(34px, 4vw, 56px); display: flex; flex-direction: column; justify-content: center; }
  .app-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 14px; }
  .app-text h2 { margin: 0; font-weight: 700; font-size: clamp(30px, 3.8vw, 46px); letter-spacing: -0.02em; line-height: 1.03; }
  .app-lead { margin: 14px 0 0; font-size: 16px; line-height: 1.55; color: var(--muted); max-width: 46ch; }
  .app-feats { display: grid; grid-template-columns: 1fr 1fr; gap: 16px 28px; margin-top: 26px; }
  .app-feat { border-top: 1px solid var(--line); padding-top: 14px; }
  .af-t { font: 600 15.5px/1.2 'Schibsted Grotesk', sans-serif; }
  .af-d { font-size: 13.5px; line-height: 1.45; color: var(--muted-2); margin-top: 5px; }
  .app-badges { display: flex; gap: 12px; margin-top: 28px; flex-wrap: wrap; }
  .badge { background: var(--ink); color: #fff; border-radius: 12px; padding: 10px 18px; display: flex; align-items: center; gap: 10px; white-space: nowrap; }
  .badge-txt { line-height: 1.15; display: flex; flex-direction: column; }
  .badge-txt small { font-size: 9.5px; color: #b7b1a4; }
  .badge-txt strong { font: 600 15px/1 'Schibsted Grotesk', sans-serif; }
  .app-img { width: 100%; height: 100%; min-height: 440px; object-fit: cover; }

  /* ---------- cta ---------- */
  .cta { max-width: 1240px; margin: 0 auto; padding: 0 32px 96px; }
  .cta-card { border-radius: 20px; background: var(--dark); color: var(--on-dark); padding: clamp(48px, 6vw, 84px) 32px; text-align: center; }
  .cta-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--terra-soft); margin: 0 0 20px; }
  .cta-card h2 { margin: 0 auto; max-width: 18ch; font-weight: 700; font-size: clamp(32px, 4.6vw, 58px); line-height: 1.02; letter-spacing: -0.025em; color: #fff; }
  .cta-lead { margin: 20px auto 0; max-width: 50ch; font-size: 17px; line-height: 1.6; color: var(--on-dark-muted); }
  .cta-card .btn-primary { margin-top: 32px; }

  /* ---------- responsive ---------- */
  @media (max-width: 880px) {
    .cite-points { grid-template-columns: 1fr; gap: 0; }
    .cite-points li { border-top: none; border-left: 2px solid var(--green); padding: 4px 0 4px 14px; margin-bottom: 14px; }
    .stats-inner { grid-template-columns: 1fr 1fr; gap: 28px 20px; }
    .sys-cards { grid-template-columns: 1fr 1fr; }
    .psteps { grid-template-columns: 1fr; }
