---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const metros = [
  {
    h: 'Lehi & Utah County',
    p: 'In Lehi and across Utah County, Homynex is installed by licensed local electricians as part of the build — not retrofitted later by a proprietary technician. It is ideal for new construction and renovation, wired alongside the rest of the home so the smart system is finished on move-in day. Every job is quoted per home, with no monthly fee.',
  },
  {
    h: 'Salt Lake City',
    p: 'Homeowners and builders across Salt Lake City have Homynex installed by their own licensed local electricians during construction or renovation. Because it is specified into the build, it suits new homes and gut renovations alike, with whole-home scope from one supplier. Pricing is quoted per home — a one-time purchase, no monthly fee.',
  },
  {
    h: 'Provo & Orem',
    p: 'In Provo and Orem, Homynex is fitted by licensed local electricians while the home is being built or renovated, so there is no separate trade to coordinate and no service lock-in. It is well suited to new construction and remodels, and is quoted per home rather than device by device. You own the system outright, with no recurring bill.',
  },
  {
    h: 'St. George',
    p: 'Down in St. George and across southern Utah, Homynex is installed by licensed local electricians during construction or renovation — ideal for new builds and home upgrades alike. The whole home runs from a single app, quoted as one package per floor plan. It is a one-time purchase with no monthly fee, owned outright.',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Homynex smart home installation',
  serviceType: 'Whole-home smart system installation',
  provider: { '@id': 'https://homienex.com/#org' },
  areaServed: [
    { '@type': 'State', name: 'Utah' },
    { '@type': 'City', name: 'Lehi' },
    { '@type': 'City', name: 'Provo' },
    { '@type': 'City', name: 'Orem' },
    { '@type': 'City', name: 'Salt Lake City' },
    { '@type': 'City', name: 'Draper' },
    { '@type': 'City', name: 'St. George' },
  ],
  description:
    "Homynex is installed by licensed local electricians across Utah's Wasatch Front, quoted per home, with no monthly fee.",
};
---

<Base
  title="Smart Home Installation in Utah — Lehi, Provo, Salt Lake City, St. George | Homynex"
  description="Homynex is installed by licensed local electricians across Utah's Wasatch Front — Lehi, Provo, Salt Lake City and St. George. A one-time purchase with no monthly fee, fitted during construction or renovation."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <Nav current="install" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-kicker">Installation &amp; service area</p>
      <h1 class="hero-h1">Smart home installation across Utah&rsquo;s Wasatch Front</h1>
      <p class="hero-sub">
        Homynex is installed by your own licensed local electrician during construction or renovation — never a
        proprietary technician. It&rsquo;s a <strong>one-time purchase with no monthly fee</strong>, quoted per home,
        across Lehi, Provo, Orem, Salt Lake City, Draper and St.&nbsp;George.
      </p>
      <div class="hero-cta-row">
        <a href="/contact/" class="btn-primary">Book a walkthrough</a>
        <a href="/how-it-works/" class="btn-line">How it works &amp; pricing &rarr;</a>
      </div>
    </div>
  </section>

  <!-- CITABLE PASSAGE -->
  <section class="cite" data-reveal>
    <div class="cite-inner">
      <p class="cite-kicker">Installation, the Homynex way</p>
      <p class="cite-text">
        Homynex is a whole-home smart system — lighting, locks, cameras, sensors, climate, audio and energy in one
        app — <strong>installed by licensed local electricians across Utah&rsquo;s Wasatch Front</strong>. It is fitted
        during construction or renovation in Lehi, Provo, Orem, Salt Lake City, Draper and St.&nbsp;George, so the smart
        system is finished alongside the rest of the home rather than bolted on afterward by a proprietary technician.
        Homynex is a <strong>one-time purchase with no monthly fee</strong>, owned outright with no contract and no
        monitoring bill, and quoted as <strong>one whole-home package per floor plan</strong> — never priced device by
        device. Because your own electrician installs it, there is no service lock-in and no separate trade to
        coordinate. Homynex is supplied by SmartSync Electric and offered statewide across Utah through a network of
        builders, electricians and designers.
      </p>
      <ul class="cite-points">
        <li><strong>Your electrician installs it.</strong> Licensed local electricians, no proprietary technician.</li>
        <li><strong>Fitted during the build.</strong> New construction and renovation across the Wasatch Front.</li>
        <li><strong>Quoted by the home.</strong> One package per floor plan — a one-time purchase, no monthly fee.</li>
      </ul>
    </div>
  </section>

  <!-- METRO BREAKDOWN -->
  <section class="metros" data-reveal>
    <div class="metros-inner">
      <div class="metros-head">
        <p class="metros-kicker">Where we install</p>
        <h2>Service across Utah&rsquo;s Wasatch Front</h2>
        <p class="metros-sub">
          Wherever you build, Homynex is installed by licensed local electricians, fitted during construction or
          renovation, and quoted per home with no monthly fee.
        </p>
      </div>
      <div class="metro-cards">
        {metros.map((m) => (
          <div class="metro-card">
            <h2 class="metro-h">{m.h}</h2>
            <p>{m.p}</p>
          </div>
        ))}
      </div>
      <nav class="metros-links" aria-label="Learn more about Homynex">
        <a href="/how-it-works/">How it works</a>
        <span class="metros-links-sep" aria-hidden="true">·</span>
        <a href="/no-monthly-fee/">No monthly fee</a>
        <span class="metros-links-sep" aria-hidden="true">·</span>
        <a href="/systems/">The 11 systems</a>
      </nav>
    </div>
  </section>

  <!-- FOR ELECTRICIANS -->
  <section class="installers" data-reveal>
    <div class="installers-card">
      <div class="installers-text">
        <p class="installers-kicker">For electricians</p>
        <h2>Become a Homynex installer</h2>
        <p class="installers-lead">
          Are you a licensed electrician serving Utah&rsquo;s Wasatch Front? Add a whole-home smart system to what you
          offer — one integrated package per home, quoted with no monthly fee, that you install alongside the work you
          already do. We&rsquo;ll handle the spec and the supply; you keep the relationship with the builder and the
          homeowner.
        </p>
        <a href="/contact/" class="btn-light">Apply to install Homynex &rarr;</a>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="cta" data-reveal>
    <div class="cta-card">
      <p class="cta-kicker">For builders &amp; homeowners</p>
      <h2>Book a walkthrough in your area</h2>
      <p class="cta-lead">
        Tell us where you&rsquo;re building and we&rsquo;ll spec one whole-home package per floor plan — installed by a
        licensed local electrician, owned outright, with no monthly fee.
      </p>
      <a href="/contact/" class="btn-primary">Book a walkthrough</a>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ---------- shared buttons ---------- */
  .btn-primary {
    text-decoration: none; background: var(--green); color: #fff; font-weight: 600; font-size: 16px;
    padding: 16px 28px; border-radius: 999px; display: inline-block;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); background: var(--green-2); }
  .btn-line {
    text-decoration: none; color: var(--green); font-weight: 600; font-size: 16px; padding: 16px 4px;
    border-bottom: 2px solid var(--green); display: inline-block; align-self: center;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .btn-line:hover { color: var(--green-2); border-bottom-color: var(--green-2); }
  .btn-light {
    text-decoration: none; background: #fff; color: var(--green); font-weight: 600; font-size: 15px;
    padding: 15px 26px; border-radius: 999px; display: inline-block; align-self: flex-start;
    transition: transform 0.2s ease;
  }
  .btn-light:hover { transform: translateY(-2px); }

  /* ---------- hero ---------- */
  .hero { max-width: 1240px; margin: 0 auto; padding: clamp(56px, 9vw, 110px) 32px clamp(20px, 4vw, 40px); }
  .hero-inner { max-width: 24ch; }
  .hero-kicker {
    font: 600 13px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--terra); margin: 0 0 18px;
  }
  .hero-h1 {
    margin: 0; color: var(--ink); font-weight: 700; font-size: clamp(40px, 6.4vw, 84px);
    line-height: 0.98; letter-spacing: -0.03em;
  }
  .hero-sub {
    color: var(--muted); font-size: clamp(16px, 1.6vw, 20px); line-height: 1.55; max-width: 58ch;
    margin: 24px 0 0;
  }
  .hero-sub strong { color: var(--ink); font-weight: 700; }
  .hero-cta-row { display: flex; gap: 20px; margin-top: 32px; flex-wrap: wrap; align-items: center; }

  /* ---------- citable passage ---------- */
  .cite { max-width: 1240px; margin: 0 auto; padding: 64px 32px 20px; }
  .cite-inner { max-width: 760px; }
  .cite-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 16px; }
  .cite-text { margin: 0; font-size: clamp(18px, 2vw, 22px); line-height: 1.6; color: var(--ink); letter-spacing: -0.005em; }
  .cite-text strong { color: var(--ink); font-weight: 700; box-shadow: inset 0 -0.5em 0 rgba(30, 91, 67, 0.12); }
  .cite-points { list-style: none; margin: 28px 0 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .cite-points li { font-size: 14.5px; line-height: 1.5; color: var(--muted); border-top: 2px solid var(--green); padding-top: 12px; }
  .cite-points strong { color: var(--ink); }

  /* ---------- metros ---------- */
  .metros { max-width: 1240px; margin: 0 auto; padding: 72px 32px 0; }
  .metros-head { max-width: 52ch; }
  .metros-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--terra); margin: 0 0 14px; }
  .metros-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; max-width: 18ch; }
  .metros-sub { margin: 14px 0 0; font-size: 17px; line-height: 1.55; color: var(--muted); max-width: 56ch; }
  .metro-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 44px 0 0; }
  .metro-card { background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 30px 28px; }
  .metro-h { margin: 0 0 12px; font-weight: 600; font-size: clamp(21px, 2.4vw, 26px); letter-spacing: -0.015em; line-height: 1.1; }
  .metro-card p { margin: 0; font-size: 15px; line-height: 1.6; color: var(--muted-2); }
  .metros-links { margin: 28px 0 0; display: flex; flex-wrap: wrap; align-items: center; gap: 6px 10px; }
  .metros-links a {
    font: 600 14px/1 'Hanken Grotesk', sans-serif; color: var(--green); text-decoration: none;
    border-bottom: 1px solid transparent; padding-bottom: 2px; transition: border-color 0.2s ease;
  }
  .metros-links a:hover { border-bottom-color: var(--green); }
  .metros-links-sep { color: var(--muted-2); font-size: 13px; }

  /* ---------- for electricians ---------- */
  .installers { max-width: 1240px; margin: 0 auto; padding: 88px 32px; }
  .installers-card {
    border-radius: 20px; background: var(--green); color: #fff;
    padding: clamp(36px, 4.5vw, 60px);
  }
  .installers-text { max-width: 56ch; }
  .installers-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: #9fcfb8; margin: 0 0 18px; }
  .installers-text h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 44px); line-height: 1.04; letter-spacing: -0.02em; max-width: 18ch; }
  .installers-lead { margin: 18px 0 28px; font-size: 16px; line-height: 1.6; color: #d6e7de; max-width: 52ch; }

  /* ---------- cta ---------- */
  .cta { max-width: 1240px; margin: 0 auto; padding: 0 32px 96px; }
  .cta-card { border-radius: 20px; background: var(--dark); color: var(--on-dark); padding: clamp(48px, 6vw, 84px) 32px; text-align: center; }
  .cta-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mint); margin: 0 0 20px; }
  .cta-card h2 { margin: 0 auto; max-width: 18ch; font-weight: 700; font-size: clamp(32px, 4.6vw, 58px); line-height: 1.02; letter-spacing: -0.025em; color: #fff; }
  .cta-lead { margin: 20px auto 0; max-width: 52ch; font-size: 17px; line-height: 1.6; color: var(--on-dark-muted); }
  .cta-card .btn-primary { margin-top: 32px; }

  /* ---------- responsive ---------- */
  @media (max-width: 880px) {
    .cite-points { grid-template-columns: 1fr; gap: 0; }
    .cite-points li { border-top: none; border-left: 2px solid var(--green); padding: 4px 0 4px 14px; margin-bottom: 14px; }
    .metro-cards { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .hero { padding: 44px 22px 8px; }
    .hero-cta-row { gap: 16px; }
    .cite { padding: 48px 22px 8px; }
    .metros { padding: 56px 22px 0; }
    .installers { padding: 64px 16px; }
    .installers-card { padding: 32px 22px; }
    .cta { padding: 0 22px 64px; }
  }
</style>
