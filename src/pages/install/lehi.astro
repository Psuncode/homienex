---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const city = 'Lehi';
const pageUrl = 'https://homienex.com/install/lehi/';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://homienex.com/' },
    { '@type': 'ListItem', position: 2, name: 'Service areas', item: 'https://homienex.com/install/' },
    { '@type': 'ListItem', position: 3, name: 'Lehi', item: pageUrl },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Smart home installation in Lehi, Utah',
  serviceType: 'Whole-home smart system installation',
  provider: { '@id': 'https://homienex.com/#org' },
  areaServed: [
    { '@type': 'City', name: 'Lehi' },
    { '@type': 'State', name: 'Utah' },
  ],
  url: pageUrl,
  description:
    'Homynex is installed in Lehi and across Utah County by licensed local electricians, quoted per home, with no monthly fee.',
};
---

<Base
  title="Smart Home Installation in Lehi, Utah — No Monthly Fee | Homynex"
  description="Homynex is installed in Lehi and across Utah County's Silicon Slopes by your own licensed local electrician — a one-time purchase with no monthly fee, fitted during construction or renovation."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <Nav current="install" />

  <!-- BREADCRUMB -->
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="crumb-inner">
      <a href="/">Home</a>
      <span class="crumb-sep" aria-hidden="true">/</span>
      <a href="/install/">Service areas</a>
      <span class="crumb-sep" aria-hidden="true">/</span>
      <span aria-current="page">Lehi</span>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-kicker">Service area · Utah County</p>
      <h1 class="hero-h1">Smart home installation in Lehi, Utah — no monthly fee</h1>
      <p class="hero-sub">
        From Traverse Mountain to the Silicon Slopes tech corridor along I-15, Homynex is installed by your own
        licensed local electrician during construction or renovation — never a proprietary technician. It&rsquo;s a
        <strong>one-time purchase with no monthly fee</strong>, quoted as one whole-home package per floor plan.
      </p>
      <div class="hero-cta-row">
        <a href="/contact/" class="btn-primary">Book a Lehi walkthrough</a>
        <a href="/how-it-works/" class="btn-line">How it works &amp; pricing &rarr;</a>
      </div>
    </div>
  </section>

  <!-- CITABLE PASSAGE -->
  <section class="cite" data-reveal>
    <div class="cite-inner">
      <p class="cite-kicker">Homynex in Lehi</p>
      <p class="cite-text">
        Homynex is a whole-home smart system — lighting, locks, cameras, sensors, climate, audio and energy in one
        app — <strong>installed in Lehi by licensed local electricians</strong>. Across Utah County and the
        Silicon Slopes corridor, it is fitted during construction or renovation, so the smart system is finished
        alongside the rest of the home rather than bolted on later by a proprietary technician. Homynex is a
        <strong>one-time purchase with no monthly fee</strong> — owned outright, with no contract and no monitoring
        bill — and quoted as <strong>one whole-home package per floor plan</strong>, never device by device. Because
        your own electrician installs it, there is no service lock-in. Homynex is supplied by SmartSync Electric and
        offered across Utah.
      </p>
      <ul class="cite-points">
        <li><strong>Your Lehi electrician installs it.</strong> Licensed local trades, no proprietary technician.</li>
        <li><strong>Fitted during the build.</strong> New construction and renovation across Utah County.</li>
        <li><strong>Quoted by the home.</strong> One package per floor plan — a one-time purchase, no monthly fee.</li>
      </ul>
    </div>
  </section>

  <!-- NEW CONSTRUCTION -->
  <section class="block" data-reveal>
    <div class="block-inner">
      <p class="block-kicker">New construction</p>
      <h2>New construction in Lehi</h2>
      <p class="block-lead">
        Lehi is one of the fastest-growing build markets on the Wasatch Front, with new neighborhoods rising around
        Traverse Mountain, Holbrook Farms and the tech campuses off I-15. When a smart system is specified into the
        plans up front, the low-voltage runs, switch locations and panel space are wired in alongside the rest of the
        home — so there is nothing to retrofit and no second visit. For builders putting up several floor plans at
        once, Homynex is specified as one package per plan, keeping the smart spec consistent across the whole
        development.
      </p>
    </div>
  </section>

  <!-- LOCAL ELECTRICIAN -->
  <section class="block block-alt" data-reveal>
    <div class="block-inner">
      <p class="block-kicker">Who does the work</p>
      <h2>Installed by your own licensed local electrician</h2>
      <p class="block-lead">
        Homynex is not a brand that sends its own crews into Lehi. It is installed by licensed local electricians —
        the trades already wiring homes across Utah County — using a single integrated package we spec and supply.
        That keeps the relationship and the warranty with a local electrician you can call, rather than a national
        call center, and it means no separate smart-home trade to schedule around the rest of the build.
      </p>
    </div>
  </section>

  <!-- PRICING -->
  <section class="block" data-reveal>
    <div class="block-inner">
      <p class="block-kicker">How it&rsquo;s priced</p>
      <h2>A one-time purchase, quoted per home</h2>
      <p class="block-lead">
        There is no monthly fee, no contract and no monitoring subscription. Homynex is bought once and owned
        outright. We quote one whole-home package per Lehi floor plan — Essentials, Enhanced or Whole-home scope —
        rather than itemizing device by device, so the cost fits inside a typical new-home upgrade budget instead of
        a lifetime of monthly payments. See <a href="/cost/">what it costs</a> and why there&rsquo;s
        <a href="/no-monthly-fee/">no monthly fee</a>.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq" data-reveal>
    <div class="faq-inner">
      <p class="faq-kicker">Common questions</p>
      <h2>Who installs smart homes in Lehi?</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h3>Who installs smart homes in Lehi?</h3>
          <p>
            Homynex is installed by licensed local electricians serving Lehi and Utah County. You keep your own
            electrician for the job — we provide the integrated smart-home package and the spec; they install it
            alongside the rest of the wiring.
          </p>
        </div>
        <div class="faq-item">
          <h3>Is there a monthly fee in Lehi?</h3>
          <p>
            No. Homynex is a one-time purchase with no monthly fee, no contract and no monitoring bill. You own the
            system outright.
          </p>
        </div>
        <div class="faq-item">
          <h3>Can it go into a home being built in Lehi?</h3>
          <p>
            Yes — that is the ideal time. Specified into the plans, Homynex is wired in during construction so the
            smart system is finished on move-in day, with nothing to retrofit later.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta" data-reveal>
    <div class="cta-card">
      <p class="cta-kicker">For builders &amp; homeowners in Lehi</p>
      <h2>Book a walkthrough in Lehi</h2>
      <p class="cta-lead">
        Tell us where you&rsquo;re building in Lehi and we&rsquo;ll spec one whole-home package per floor plan —
        installed by a licensed local electrician, owned outright, with no monthly fee.
      </p>
      <a href="/contact/" class="btn-primary">Book a walkthrough</a>
      <p class="cta-back"><a href="/install/">&larr; All Utah service areas</a></p>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ---------- shared buttons ---------- */
  .btn-primary {
    text-decoration: none; background: var(--green); color: #fff; font-weight: 600; font-size: 16px;
    padding: 16px 28px; border-radius: 999px; display: inline-block;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); background: var(--green-2); }
  .btn-line {
    text-decoration: none; color: var(--green); font-weight: 600; font-size: 16px; padding: 16px 4px;
    border-bottom: 2px solid var(--green); display: inline-block; align-self: center;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .btn-line:hover { color: var(--green-2); border-bottom-color: var(--green-2); }

  /* ---------- breadcrumb ---------- */
  .crumb { max-width: 1240px; margin: 0 auto; padding: 22px 32px 0; }
  .crumb-inner { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; font: 500 13.5px/1 'Hanken Grotesk', sans-serif; color: var(--muted); }
  .crumb-inner a { color: var(--muted); text-decoration: none; border-bottom: 1px solid transparent; padding-bottom: 1px; transition: color 0.2s ease, border-color 0.2s ease; }
  .crumb-inner a:hover { color: var(--green); border-bottom-color: var(--green); }
  .crumb-inner [aria-current='page'] { color: var(--ink); font-weight: 600; }
  .crumb-sep { color: var(--muted-2); }

  /* ---------- hero ---------- */
  .hero { max-width: 1240px; margin: 0 auto; padding: clamp(32px, 5vw, 64px) 32px clamp(20px, 4vw, 40px); }
  .hero-inner { max-width: 22ch; }
  .hero-kicker { font: 600 13px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.16em; text-transform: uppercase; color: var(--terra); margin: 0 0 18px; }
  .hero-h1 { margin: 0; color: var(--ink); font-weight: 700; font-size: clamp(38px, 6vw, 78px); line-height: 0.98; letter-spacing: -0.03em; }
  .hero-sub { color: var(--muted); font-size: clamp(16px, 1.6vw, 20px); line-height: 1.55; max-width: 58ch; margin: 24px 0 0; }
  .hero-sub strong { color: var(--ink); font-weight: 700; }
  .hero-cta-row { display: flex; gap: 20px; margin-top: 32px; flex-wrap: wrap; align-items: center; }

  /* ---------- citable passage ---------- */
  .cite { max-width: 1240px; margin: 0 auto; padding: 64px 32px 20px; }
  .cite-inner { max-width: 760px; }
  .cite-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 16px; }
  .cite-text { margin: 0; font-size: clamp(18px, 2vw, 22px); line-height: 1.6; color: var(--ink); letter-spacing: -0.005em; }
  .cite-text strong { color: var(--ink); font-weight: 700; box-shadow: inset 0 -0.5em 0 rgba(30, 91, 67, 0.12); }
  .cite-points { list-style: none; margin: 28px 0 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .cite-points li { font-size: 14.5px; line-height: 1.5; color: var(--muted); border-top: 2px solid var(--green); padding-top: 12px; }
  .cite-points strong { color: var(--ink); }

  /* ---------- content blocks ---------- */
  .block { max-width: 1240px; margin: 0 auto; padding: 56px 32px 0; }
  .block-inner { max-width: 720px; }
  .block-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--terra); margin: 0 0 14px; }
  .block-inner h2 { margin: 0; font-weight: 700; font-size: clamp(26px, 3.4vw, 42px); letter-spacing: -0.02em; line-height: 1.05; max-width: 20ch; }
  .block-lead { margin: 16px 0 0; font-size: 16.5px; line-height: 1.65; color: var(--muted); }
  .block-alt .block-kicker { color: var(--green); }

  /* ---------- faq ---------- */
  .faq { max-width: 1240px; margin: 0 auto; padding: 72px 32px 0; }
  .faq-inner { max-width: 760px; }
  .faq-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 14px; }
  .faq-inner > h2 { margin: 0 0 28px; font-weight: 700; font-size: clamp(26px, 3.4vw, 42px); letter-spacing: -0.02em; line-height: 1.05; }
  .faq-list { display: grid; gap: 18px; }
  .faq-item { background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 24px 26px; }
  .faq-item h3 { margin: 0 0 8px; font-weight: 600; font-size: 18px; letter-spacing: -0.01em; line-height: 1.2; }
  .faq-item p { margin: 0; font-size: 15px; line-height: 1.6; color: var(--muted-2); }

  /* ---------- cta ---------- */
  .cta { max-width: 1240px; margin: 0 auto; padding: 72px 32px 96px; }
  .cta-card { border-radius: 20px; background: var(--dark); color: var(--on-dark); padding: clamp(48px, 6vw, 84px) 32px; text-align: center; }
  .cta-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mint); margin: 0 0 20px; }
  .cta-card h2 { margin: 0 auto; max-width: 18ch; font-weight: 700; font-size: clamp(32px, 4.6vw, 56px); line-height: 1.02; letter-spacing: -0.025em; color: #fff; }
  .cta-lead { margin: 20px auto 0; max-width: 52ch; font-size: 17px; line-height: 1.6; color: var(--on-dark-muted); }
  .cta-card .btn-primary { margin-top: 32px; }
  .cta-back { margin: 24px 0 0; font-size: 14px; }
  .cta-back a { color: var(--on-dark-muted); text-decoration: none; border-bottom: 1px solid transparent; padding-bottom: 2px; transition: color 0.2s ease, border-color 0.2s ease; }
  .cta-back a:hover { color: #fff; border-bottom-color: var(--mint); }

  /* ---------- responsive ---------- */
  @media (max-width: 880px) {
    .cite-points { grid-template-columns: 1fr; gap: 0; }
    .cite-points li { border-top: none; border-left: 2px solid var(--green); padding: 4px 0 4px 14px; margin-bottom: 14px; }
  }
  @media (max-width: 560px) {
    .crumb { padding: 18px 22px 0; }
    .hero { padding: 28px 22px 8px; }
    .cite { padding: 48px 22px 8px; }
    .block { padding: 44px 22px 0; }
    .faq { padding: 56px 22px 0; }
    .cta { padding: 56px 22px 64px; }
  }
</style>
