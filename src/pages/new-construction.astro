---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const prewire = [
  {
    n: '01',
    t: 'Wired while the walls are open',
    d: 'The cleanest, cheapest moment to wire a smart home is before the drywall goes up. During the build, runs are pulled and devices placed without cutting into finished walls or fishing cable through insulation.',
  },
  {
    n: '02',
    t: 'Installed by your own electrician',
    d: 'The licensed electrician already wiring your home installs it — no special low-voltage contractor and no proprietary technician to schedule. It is one more line on the work the trade is already doing.',
  },
  {
    n: '03',
    t: 'Cheaper than retrofitting later',
    d: 'Adding automation to a finished home means opening walls, patching and repainting. Building it in from the start avoids that rework, so the same systems cost less to install during construction than after move-in.',
  },
  {
    n: '04',
    t: 'One ecosystem, one app',
    d: 'Entry, lighting, climate, security, audio and energy come from a single source and run in one app — not a drawer of mismatched gadgets bolted on after the fact.',
  },
];

const owned = [
  {
    n: '01',
    t: 'Bought once, owned outright',
    d: 'Homynex is a one-time purchase that becomes part of the house — like the cabinets or the HVAC. You own the system, not a license to keep paying for it.',
  },
  {
    n: '02',
    t: 'No contract, no monitoring bill',
    d: 'There is no subscription that follows you home and no monthly monitoring fee. Nothing recurring is required to keep your lights, locks and climate working.',
  },
  {
    n: '03',
    t: 'Nothing to cancel at closing',
    d: 'Because it is an owned upgrade rather than a service, there is no account to transfer and no contract for a future buyer to inherit — it simply stays with the home.',
  },
];

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://homienex.com/new-construction/',
  url: 'https://homienex.com/new-construction/',
  name: 'Smart Home for New Construction — Wired In, Owned Outright',
  description:
    'Pre-wire your new home for whole-home automation during the build, installed by your own licensed electrician. A one-time purchase with no monthly fee — owned outright, and a value-adding upgrade.',
  about: {
    '@type': 'Service',
    name: 'Homynex for new construction',
    serviceType: 'Whole-home smart system pre-wired during construction',
    description:
      'A whole-home smart system — eleven integrated systems in one app — pre-wired into a new home during the build by a licensed local electrician, sold as a one-time purchase with no monthly fee and owned outright.',
    provider: {
      '@type': 'Organization',
      name: 'Homynex',
      url: 'https://homienex.com',
      parentOrganization: { '@type': 'Organization', name: 'SmartSync Electric Ltd' },
    },
    areaServed: { '@type': 'State', name: 'Utah' },
  },
  isPartOf: { '@type': 'WebSite', name: 'Homynex', url: 'https://homienex.com' },
};
---

<Base
  title="Smart Home for New Construction — Wired In, Owned Outright | Homynex"
  description="Pre-wire your new home for whole-home automation, installed by your own licensed electrician during the build. A one-time purchase with no monthly fee — owned outright, and a value-adding upgrade."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  </Fragment>

  <Nav current="builders" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-media">
      <picture style="display:contents">
        <source type="image/webp" srcset="/catalog_images/p51_1.webp" />
        <img
          src="/catalog_images/p51_1.jpg"
          alt="A newly built living room at dusk with integrated Homynex lighting, climate and shades wired in during construction"
          class="hero-img"
          fetchpriority="high"
          decoding="async"
          width="1320"
          height="720"
        />
      </picture>
      <div class="hero-scrim" aria-hidden="true"></div>
    </div>
    <div class="hero-content">
      <p class="hero-kicker">For new construction</p>
      <h1 class="hero-h1">Smart home for new construction — wired in during the build, owned outright</h1>
      <p class="hero-sub">
        Pre-wire your new home for whole-home automation while the walls are still open — installed by
        your own licensed electrician, not a proprietary technician. A <strong>one-time purchase with no
        monthly fee</strong>, owned like the house itself.
      </p>
      <div class="hero-cta-row">
        <a href="/contact/" class="btn-primary">Plan your pre-wire</a>
        <a href="/how-it-works/" class="btn-ghost">How it works</a>
      </div>
      <ul class="hero-chips">
        <li>Pre-wired during the build</li>
        <li>$0 / month — ever</li>
        <li>Owned outright</li>
      </ul>
    </div>
  </section>

  <!-- CITABLE PASSAGE -->
  <section class="cite" data-reveal>
    <div class="cite-inner">
      <p class="cite-kicker">Smart home for new construction</p>
      <p class="cite-text">
        A smart home for new construction is best <strong>pre-wired during the build</strong>, while the
        walls are still open — the cheapest, cleanest moment to run cable and place devices, before any
        drywall, patching or repainting is needed. With Homynex, the
        <strong>licensed electrician already wiring your home installs it</strong> — no special low-voltage
        contractor and no proprietary technician required. The result is one integrated ecosystem —
        eleven systems spanning entry, lighting, climate, security, audio and energy — controlled from a
        single app. Homynex is a <strong>one-time purchase with no monthly fee</strong>: you own the
        system outright, with no contract and no monitoring bill, so it becomes part of the house rather
        than a subscription. Homynex is supplied by SmartSync Electric and serves Utah's Wasatch Front.
      </p>
      <ul class="cite-points">
        <li><strong>Pre-wired in the build.</strong> Cheaper and cleaner than retrofitting a finished home.</li>
        <li><strong>Your electrician installs it.</strong> No special low-voltage contractor needed.</li>
        <li><strong>Owned outright.</strong> A one-time purchase, no monthly fee — not a subscription.</li>
      </ul>
    </div>
  </section>

  <!-- PRE-WIRE DURING THE BUILD -->
  <section class="prewire" data-reveal>
    <div class="prewire-inner">
      <div class="prewire-head">
        <p class="prewire-kicker">Pre-wire during the build</p>
        <h2>Build the smart home in — don't bolt it on later.</h2>
        <p class="prewire-sub">
          The cheapest time to wire whole-home automation is while the walls are still open, installed by
          the same licensed electrician already on your home — no special low-voltage contractor, no rework
          after move-in.
        </p>
      </div>
      <div class="prewire-cards">
        {prewire.map((p) => (
          <div class="prewire-card">
            <div class="prewire-n">{p.n}</div>
            <h3>{p.t}</h3>
            <p>{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RESALE VALUE -->
  <section class="resale" data-reveal>
    <div class="resale-inner">
      <div class="resale-head">
        <p class="resale-kicker">Does a smart home add resale value?</p>
        <h2>A value-adding upgrade — by industry estimates, not a guarantee.</h2>
        <p class="resale-sub">
          A built-in smart home is generally viewed as a desirable, value-adding feature. Industry
          estimates suggest smart-home features can command a modest price premium and help homes sell
          faster — but figures vary by market, and these are general estimates, not a Homynex promise.
        </p>
      </div>
      <div class="resale-cards">
        <div class="resale-card">
          <p class="resale-tag">Industry estimates</p>
          <h3>A few percent premium</h3>
          <p>
            Industry estimates commonly cite a smart-home premium of roughly a few percent on a home's sale
            price. Actual impact depends on the market, the buyer and how well the systems are integrated —
            so treat any single number as an estimate, not a fixed return.
          </p>
        </div>
        <div class="resale-card">
          <p class="resale-tag">Industry estimates</p>
          <h3>Often sells faster</h3>
          <p>
            Homes marketed with integrated smart features are widely reported to attract more interest and
            sell faster than comparable homes without them. Again, this reflects general industry estimates
            rather than a guaranteed outcome for any specific home.
          </p>
        </div>
        <div class="resale-card">
          <p class="resale-tag">Why it shows well</p>
          <h3>Owned, not a subscription</h3>
          <p>
            Because Homynex is owned outright with no monthly fee, a future buyer inherits a working,
            paid-for system — not a contract to take over. An owned upgrade is an easier story at resale
            than a subscription that follows the home.
          </p>
        </div>
      </div>
      <p class="resale-note">
        Resale figures referenced above are general industry estimates for smart-home features. They are
        provided for context and are not a guarantee of value, a price premium or a faster sale by Homynex.
      </p>
    </div>
  </section>

  <!-- ONE-TIME PURCHASE -->
  <section class="owned" data-reveal>
    <div class="owned-inner">
      <div class="owned-head">
        <p class="owned-kicker">One-time purchase, no monthly fee</p>
        <h2>An owned upgrade — not a subscription.</h2>
        <p class="owned-sub">
          Homynex is bought once and owned outright, like the rest of the house. No contract, no monitoring
          bill, nothing recurring required to keep it working.
        </p>
      </div>
      <div class="owned-cards">
        {owned.map((o) => (
          <div class="owned-card">
            <div class="owned-n">{o.n}</div>
            <h3>{o.t}</h3>
            <p>{o.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="cta" data-reveal>
    <div class="cta-card">
      <p class="cta-kicker">For new construction</p>
      <h2>Plan your smart-home pre-wire</h2>
      <p class="cta-lead">
        Wiring whole-home automation in during the build is the cheapest, cleanest way to do it — installed
        by your own electrician, owned outright, with no monthly fee. Tell us about your new home and we'll
        scope the pre-wire.
      </p>
      <a href="/contact/" class="btn-primary">Plan your pre-wire</a>
      <nav class="cta-links" aria-label="Learn more">
        <a href="/builders/">Building multiple homes? See Homynex for builders</a>
        <span class="cta-links-sep" aria-hidden="true">·</span>
        <a href="/how-it-works/">How it works</a>
      </nav>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ---------- shared buttons ---------- */
  .btn-primary {
    text-decoration: none; background: var(--green); color: #fff; font-weight: 600; font-size: 16px;
    padding: 16px 28px; border-radius: 999px; display: inline-block;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); background: var(--green-2); }
  .btn-ghost {
    text-decoration: none; background: rgba(255, 255, 255, 0.16); -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px); color: #fff; font-weight: 600; font-size: 16px; padding: 16px 28px;
    border-radius: 999px; border: 1px solid rgba(255, 255, 255, 0.45); display: inline-block;
    transition: background 0.2s ease;
  }
  .btn-ghost:hover { background: rgba(255, 255, 255, 0.28); }

  /* ---------- hero ---------- */
  .hero { max-width: 1320px; margin: 0 auto; padding: 28px 24px 0; }
  .hero-media {
    position: relative; border-radius: 20px; overflow: hidden;
    height: clamp(520px, 68vh, 720px);
  }
  .hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .hero-scrim {
    position: absolute; inset: 0; pointer-events: none;
    background:
      linear-gradient(180deg, rgba(15, 12, 9, 0.2) 0%, rgba(15, 12, 9, 0.1) 34%, rgba(15, 12, 9, 0.78) 100%),
      linear-gradient(90deg, rgba(15, 12, 9, 0.55) 0%, rgba(15, 12, 9, 0.12) 48%, rgba(15, 12, 9, 0) 70%);
  }
  .hero-content { position: absolute; left: 0; right: 0; bottom: 0; padding: clamp(28px, 5vw, 60px); }
  .hero-kicker {
    font: 600 13px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.16em; text-transform: uppercase;
    color: #ebd9c4; margin: 0 0 18px;
  }
  .hero-h1 {
    margin: 0; color: #fff; font-weight: 700; font-size: clamp(40px, 6.4vw, 84px);
    line-height: 0.98; letter-spacing: -0.03em; max-width: 19ch; text-shadow: 0 2px 30px rgba(0, 0, 0, 0.25);
  }
  .hero-sub { color: #f0eae0; font-size: clamp(16px, 1.5vw, 20px); line-height: 1.5; max-width: 56ch; margin: 22px 0 0; }
  .hero-sub strong { color: #fff; }
  .hero-cta-row { display: flex; gap: 14px; margin-top: 30px; flex-wrap: wrap; }
  .hero-chips {
    display: flex; gap: 10px; flex-wrap: wrap; list-style: none; margin: 26px 0 0; padding: 0;
  }
  .hero-chips li {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; color: #fff; letter-spacing: 0.02em;
    background: rgba(255, 255, 255, 0.14); border: 1px solid rgba(255, 255, 255, 0.34);
    padding: 9px 14px; border-radius: 999px; -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
  }

  /* ---------- citable passage ---------- */
  .cite { max-width: 1240px; margin: 0 auto; padding: 80px 32px 20px; }
  .cite-inner { max-width: 760px; }
  .cite-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 16px; }
  .cite-text { margin: 0; font-size: clamp(18px, 2vw, 22px); line-height: 1.6; color: var(--ink); letter-spacing: -0.005em; }
  .cite-text strong { color: var(--ink); font-weight: 700; box-shadow: inset 0 -0.5em 0 rgba(30, 91, 67, 0.12); }
  .cite-points { list-style: none; margin: 28px 0 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .cite-points li { font-size: 14.5px; line-height: 1.5; color: var(--muted); border-top: 2px solid var(--green); padding-top: 12px; }
  .cite-points strong { color: var(--ink); }

  /* ---------- pre-wire during the build ---------- */
  .prewire { max-width: 1240px; margin: 0 auto; padding: 80px 32px 20px; }
  .prewire-head { max-width: 760px; }
  .prewire-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 14px; }
  .prewire-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; max-width: 20ch; }
  .prewire-sub { margin: 14px 0 0; font-size: 17px; line-height: 1.55; color: var(--muted); max-width: 54ch; }
  .prewire-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 44px; }
  .prewire-card { background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 28px 26px; }
  .prewire-n { font: 700 15px/1 'Schibsted Grotesk', sans-serif; color: var(--terra); }
  .prewire-card h3 { margin: 16px 0 10px; font-weight: 600; font-size: 19px; letter-spacing: -0.01em; line-height: 1.15; }
  .prewire-card p { margin: 0; font-size: 14px; line-height: 1.55; color: var(--muted-2); }

  /* ---------- resale value ---------- */
  .resale { background: #efeadf; border-top: 1px solid var(--line-2); border-bottom: 1px solid var(--line-2); margin-top: 60px; }
  .resale-inner { max-width: 1240px; margin: 0 auto; padding: 84px 32px; }
  .resale-head { max-width: 780px; }
  .resale-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 14px; }
  .resale-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; max-width: 22ch; }
  .resale-sub { margin: 14px 0 0; font-size: 17px; line-height: 1.55; color: var(--muted); max-width: 58ch; }
  .resale-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 44px; }
  .resale-card { background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 30px 28px; display: flex; flex-direction: column; }
  .resale-tag { margin: 0 0 14px; font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.04em; text-transform: uppercase; color: var(--terra); }
  .resale-card h3 { margin: 0; font-weight: 700; font-size: 22px; letter-spacing: -0.01em; line-height: 1.1; }
  .resale-card p { margin: 14px 0 0; font-size: 14.5px; line-height: 1.55; color: var(--muted-2); }
  .resale-note { margin: 28px 0 0; max-width: 78ch; font-size: 13px; line-height: 1.55; color: var(--muted); font-style: italic; }

  /* ---------- one-time purchase ---------- */
  .owned { max-width: 1240px; margin: 0 auto; padding: 84px 32px; }
  .owned-head { max-width: 760px; }
  .owned-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin: 0 0 14px; }
  .owned-head h2 { margin: 0; font-weight: 700; font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -0.02em; line-height: 1.04; max-width: 18ch; }
  .owned-sub { margin: 14px 0 0; font-size: 17px; line-height: 1.55; color: var(--muted); max-width: 54ch; }
  .owned-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 44px; }
  .owned-card { background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 28px 26px; }
  .owned-n { font: 700 15px/1 'Schibsted Grotesk', sans-serif; color: var(--terra); }
  .owned-card h3 { margin: 16px 0 10px; font-weight: 600; font-size: 20px; letter-spacing: -0.01em; line-height: 1.15; }
  .owned-card p { margin: 0; font-size: 14.5px; line-height: 1.55; color: var(--muted-2); }

  /* ---------- cta ---------- */
  .cta { max-width: 1240px; margin: 0 auto; padding: 20px 32px 96px; }
  .cta-card { border-radius: 20px; background: var(--dark); color: var(--on-dark); padding: clamp(48px, 6vw, 84px) 32px; text-align: center; }
  .cta-kicker { font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mint); margin: 0 0 20px; }
  .cta-card h2 { margin: 0 auto; max-width: 18ch; font-weight: 700; font-size: clamp(32px, 4.6vw, 58px); line-height: 1.02; letter-spacing: -0.025em; color: #fff; }
  .cta-lead { margin: 20px auto 0; max-width: 54ch; font-size: 17px; line-height: 1.6; color: var(--on-dark-muted); }
  .cta-card .btn-primary { margin-top: 32px; }
  .cta-links { margin-top: 22px; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 6px 12px; }
  .cta-links a {
    font: 600 14px/1 'Hanken Grotesk', sans-serif; color: var(--mint); text-decoration: none;
    border-bottom: 1px solid transparent; padding-bottom: 2px; transition: border-color 0.2s ease;
  }
  .cta-links a:hover { border-bottom-color: var(--mint); }
  .cta-links-sep { color: var(--on-dark-muted); font-size: 13px; }

  /* ---------- responsive ---------- */
  @media (max-width: 880px) {
    .cite-points { grid-template-columns: 1fr; gap: 0; }
    .cite-points li { border-top: none; border-left: 2px solid var(--green); padding: 4px 0 4px 14px; margin-bottom: 14px; }
    .prewire-cards { grid-template-columns: 1fr 1fr; }
    .resale-cards { grid-template-columns: 1fr; }
    .owned-cards { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .hero { padding: 16px 14px 0; }
    .cite { padding: 56px 22px 8px; }
    .prewire { padding: 56px 22px 8px; }
    .prewire-cards { grid-template-columns: 1fr; }
    .resale-inner { padding: 60px 22px; }
    .owned { padding: 60px 22px; }
    .cta { padding: 16px 22px 64px; }
  }
</style>
