---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Privacy Policy | Homynex"
  description="How Homynex collects, uses and protects the information you share through our contact form."
>
  <Nav />

  <section class="legal">
    <div class="legal-inner">
      <p class="legal-note">This is a placeholder; final legal copy pending counsel.</p>
      <p class="legal-kicker">Legal</p>
      <h1 class="legal-h1">Privacy Policy</h1>
      <p class="legal-updated">Last updated June 22, 2026</p>

      <h2>What we collect</h2>
      <p>
        When you reach out through our contact form, we collect the details you choose to provide —
        such as your name, email address, phone number, and anything you tell us about your project
        or development. We do not sell your information.
      </p>

      <h2>How we use it</h2>
      <p>
        We use what you share to respond to your enquiry, schedule a walkthrough, and prepare a quote
        for your home or development. We keep it only as long as we need to help you and to maintain
        our records.
      </p>

      <h2>Sharing</h2>
      <p>
        Homynex is supplied by SmartSync Electric. We may share relevant details with the licensed
        local electricians, builders or designers involved in your project so they can serve you. We
        do not share your information for unrelated marketing.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about your information, or want it updated or removed? Email us at
        <a href="mailto:hello@homienex.com">hello@homienex.com</a>.
      </p>
    </div>
  </section>

  <Footer />
</Base>

<style>
  .legal { max-width: 1240px; margin: 0 auto; padding: clamp(56px, 9vh, 96px) 32px clamp(64px, 10vh, 112px); }
  .legal-inner { max-width: 760px; }
  .legal-note {
    margin: 0 0 28px; font-size: 13.5px; line-height: 1.5; color: var(--muted-2);
    background: #efeadf; border: 1px solid var(--line-2); border-radius: 10px; padding: 12px 16px;
  }
  .legal-kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--green); margin: 0 0 16px;
  }
  .legal-h1 {
    margin: 0; font-weight: 700; font-size: clamp(36px, 5.2vw, 60px); line-height: 1.0;
    letter-spacing: -0.03em; color: var(--ink);
  }
  .legal-updated {
    margin: 18px 0 0; font: 600 13px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.04em;
    color: var(--muted-2);
  }
  .legal-inner h2 {
    margin: 44px 0 12px; font-weight: 600; font-size: clamp(20px, 2.4vw, 26px); letter-spacing: -0.01em;
    color: var(--ink);
  }
  .legal-inner p {
    margin: 0; font-size: clamp(16px, 1.5vw, 18px); line-height: 1.65; color: var(--muted);
  }
  .legal-inner a {
    color: var(--green); font-weight: 600; text-decoration: none;
    border-bottom: 1px solid rgba(30, 91, 67, 0.35); padding-bottom: 1px;
  }
  .legal-inner a:hover { border-bottom-color: var(--green); }
  @media (max-width: 560px) {
    .legal { padding: 48px 22px 64px; }
  }
</style>
