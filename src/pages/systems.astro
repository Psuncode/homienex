---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { systems } from '../data/systems.js';

// Filter tabs. Each tab's `tag` matches a card's data-tag (a system.tag value),
// except "all" which shows every card. Without JS, every card stays visible.
const tabs = [
  { tag: 'all', label: 'All systems' },
  { tag: 'Access & Security', label: 'Access & Security' },
  { tag: 'Lighting & Power', label: 'Lighting & Power' },
  { tag: 'Sensors & Control', label: 'Sensors & Control' },
  { tag: 'Comfort & Climate', label: 'Comfort & Climate' },
  { tag: 'Audio & Energy', label: 'Audio & Energy' },
];

// The Entry System (id 0) links to its own detail page.
const detailHref = (s) => (s.id === 0 ? '/systems/entry/' : null);

// Descriptive alt text per system, keyed by name — avoids the duplicate
// "Name — Name" alts produced from `${name} — ${tag}`.
const systemAlts = {
  'Entry System': 'Smart lock and video doorbell at a front door',
  'Lighting & Power': 'In-wall smart light switch and dimmer',
  'Sensors & Control': 'Smart scene panel and motion sensor',
  'Video Surveillance': 'Pan-tilt security camera',
  'Comfort & Climate': 'Smart thermostat on a wall',
  'Background Music': 'Architectural ceiling speaker',
  'Security System': 'Smart alarm keypad and sensors',
  'Blinds & Curtains': 'Motorized roller blinds on a window',
  'Whole-Home Wi-Fi': 'Mesh Wi-Fi node',
  'Home Backup Power': 'Home battery wall and solar storage',
  'Smart Peripherals': 'Smart track lighting',
};

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'The 11 Homynex systems',
  url: 'https://homynex.com/systems',
  about: { '@id': 'https://homynex.com/#org' },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: 11,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Entry System', url: 'https://homynex.com/systems/entry' },
      { '@type': 'ListItem', position: 2, name: 'Lighting & Power' },
      { '@type': 'ListItem', position: 3, name: 'Sensors & Control' },
      { '@type': 'ListItem', position: 4, name: 'Video Surveillance' },
      { '@type': 'ListItem', position: 5, name: 'Comfort & Climate' },
      { '@type': 'ListItem', position: 6, name: 'Background Music' },
      { '@type': 'ListItem', position: 7, name: 'Security System' },
      { '@type': 'ListItem', position: 8, name: 'Blinds & Curtains' },
      { '@type': 'ListItem', position: 9, name: 'Whole-Home Wi-Fi' },
      { '@type': 'ListItem', position: 10, name: 'Home Backup Power' },
      { '@type': 'ListItem', position: 11, name: 'Smart Peripherals' },
    ],
  },
};
---

<Base
  title="The 11 Homynex Systems | Whole-Home Smart, One Ecosystem"
  description="Explore all eleven integrated Homynex systems — entry, lighting, climate, security, audio and energy — in one app. A one-time purchase with no monthly fee, installed by your local electrician."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  </Fragment>

  <div id="page-content">
  <Nav current="systems" />

  <!-- HEADER -->
  <section class="head">
    <div class="head-inner">
      <p class="kicker">The full catalog</p>
      <h1 class="head-h1">Eleven systems, one ecosystem</h1>
      <p class="head-intro">
        Every Homynex system is built to integrate — sharing one app, one set of scenes, and one
        connected platform. It is a one-time purchase with no monthly fee, installed by your local
        electrician and quoted per home. Filter the range below, then open any system for its full
        product list.
      </p>
      <nav class="head-links" aria-label="Learn more about Homynex">
        <a href="/how-it-works/">How pricing works</a>
        <span class="head-links-sep" aria-hidden="true">·</span>
        <a href="/no-monthly-fee/">Why there's no monthly fee</a>
      </nav>
    </div>
  </section>

  <!-- FILTER TABS -->
  <section class="filter" data-reveal aria-label="Filter systems by category">
    <div class="filter-inner">
      <div class="tabs" role="group" aria-label="System categories">
        {tabs.map((t, i) => (
          <button
            type="button"
            class="tab"
            data-tag={t.tag}
            aria-pressed={i === 0 ? 'true' : 'false'}
          >
            {t.label}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- GRID -->
  <section class="grid-sec" data-reveal>
    <div class="grid-inner">
      <ul class="cards" id="sys-cards">
        {systems.map((s) => (
          <li class="card-wrap" data-tag={s.tag}>
            <button
              type="button"
              class="card"
              data-modal-open={`modal-${s.id}`}
              aria-haspopup="dialog"
            >
              <img
                src={s.img}
                alt={systemAlts[s.name] || s.name}
                class="card-img"
                loading="lazy"
                decoding="async"
                width="400"
                height="180"
              />
              <span class="card-body">
                <span class="card-meta">
                  <span class="card-n">{s.n}</span>
                  <span class="card-count">{s.products.length} products</span>
                </span>
                <span class="card-name">{s.name}</span>
                <span class="card-desc">{s.desc}</span>
                <span class="card-cta">Quick view →</span>
              </span>
            </button>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="cta" data-reveal>
    <div class="cta-card">
      <h2>See every system working together</h2>
      <p class="cta-lead">
        One supplier, one app, no monthly fee. Book a guided walkthrough of all eleven integrated
        systems and see how they share scenes across the whole home.
      </p>
      <a href="/contact/" class="btn-primary">Book a walkthrough</a>
    </div>
  </section>

  <Footer />
  </div>

  <!-- QUICK-VIEW MODALS — all 11 rendered in the DOM (crawlable), hidden via [hidden]. -->
  {systems.map((s) => (
    <div
      class="modal"
      id={`modal-${s.id}`}
      role="dialog"
      aria-modal="true"
      aria-labelledby={`modal-${s.id}-title`}
      hidden
    >
      <div class="modal-backdrop" data-modal-close></div>
      <div class="modal-dialog" tabindex="-1">
        <button type="button" class="modal-x" data-modal-close aria-label="Close quick view">✕</button>
        <img
          src={s.img}
          alt={systemAlts[s.name] || s.name}
          class="modal-img"
          loading="lazy"
          decoding="async"
          width="780"
          height="220"
        />
        <div class="modal-body">
          <p class="modal-tag">{s.tag}</p>
          <div class="modal-titlerow">
            <span class="modal-n">{s.n}</span>
            <h2 class="modal-title" id={`modal-${s.id}-title`}>{s.name}</h2>
          </div>
          <p class="modal-desc">{s.desc}</p>
          <p class="modal-eyebrow">Products in this system</p>
          <ul class="modal-products">
            {s.products.map((p) => (<li>{p}</li>))}
          </ul>
          <div class="modal-actions">
            {detailHref(s) && (
              <a href={detailHref(s)} class="btn-outline">View the {s.name} →</a>
            )}
            <a href="/contact/" class="btn-primary modal-quote">Request a quote for this system</a>
          </div>
        </div>
      </div>
    </div>
  ))}
</Base>

<style>
  /* ---------- shared buttons ---------- */
  .btn-primary {
    text-decoration: none; background: var(--green); color: #fff; font-weight: 600; font-size: 16px;
    padding: 16px 28px; border-radius: 999px; display: inline-block; border: none; cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); background: var(--green-2); }
  .btn-outline {
    text-decoration: none; background: transparent; color: var(--green); font-weight: 600; font-size: 15px;
    padding: 14px 24px; border-radius: 999px; display: inline-block; border: 1px solid var(--green);
    transition: background 0.2s ease, color 0.2s ease;
  }
  .btn-outline:hover { background: var(--green); color: #fff; }

  /* ---------- header ---------- */
  .head { max-width: 1240px; margin: 0 auto; padding: 72px 32px 36px; }
  .head-inner { max-width: 760px; }
  .kicker {
    font: 600 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--green); margin: 0 0 20px;
  }
  .head-h1 {
    margin: 0; max-width: 20ch; font-weight: 700; font-size: clamp(40px, 6vw, 76px);
    line-height: 0.98; letter-spacing: -0.03em;
  }
  .head-intro {
    margin: 24px 0 0; max-width: 58ch; font-size: clamp(16px, 1.7vw, 18px); line-height: 1.6; color: var(--muted);
  }
  .head-links { margin-top: 18px; display: flex; flex-wrap: wrap; align-items: center; gap: 6px 10px; }
  .head-links a {
    font: 600 14px/1 'Hanken Grotesk', sans-serif; color: var(--green); text-decoration: none;
    border-bottom: 1px solid transparent; padding-bottom: 2px; transition: border-color 0.2s ease;
  }
  .head-links a:hover { border-bottom-color: var(--green); }
  .head-links-sep { color: var(--muted-2); font-size: 13px; }

  /* ---------- filter ---------- */
  .filter { max-width: 1240px; margin: 0 auto; padding: 8px 32px 0; }
  .tabs { display: flex; flex-wrap: wrap; gap: 10px; }
  .tab {
    font: 600 14px/1 'Hanken Grotesk', sans-serif; white-space: nowrap; padding: 11px 18px;
    border-radius: 999px; cursor: pointer; background: transparent; color: var(--muted);
    border: 1px solid #d8d1c4; transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .tab:hover { border-color: var(--green); color: var(--green); }
  .tab[aria-pressed='true'] { background: var(--dark); color: var(--on-dark); border-color: var(--dark); }

  /* ---------- grid ---------- */
  .grid-sec { max-width: 1240px; margin: 0 auto; padding: 32px 32px 96px; }
  .cards { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .card-wrap[hidden] { display: none; }
  .card {
    display: block; width: 100%; text-align: left; padding: 0; cursor: pointer; color: inherit;
    background: #fff; border: 1px solid var(--line); border-radius: 16px; overflow: hidden; font: inherit;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .card:hover { transform: translateY(-6px); border-color: var(--green); box-shadow: 0 18px 40px rgba(22, 20, 18, 0.1); }
  .card-img { width: 100%; height: 180px; object-fit: cover; background: #ece7dd; }
  .card-body { display: block; padding: 20px 22px 24px; }
  .card-meta { display: flex; align-items: baseline; justify-content: space-between; }
  .card-n { font: 700 15px/1 'Schibsted Grotesk', sans-serif; color: var(--terra); }
  .card-count { font-size: 12px; color: var(--muted-2); font-weight: 500; }
  .card-name { display: block; margin: 16px 0 8px; font: 600 21px/1.1 'Schibsted Grotesk', sans-serif; letter-spacing: -0.01em; }
  .card-desc { display: block; margin: 0; font-size: 14px; line-height: 1.5; color: var(--muted-2); }
  .card-cta { display: block; margin-top: 18px; font-weight: 600; font-size: 14px; color: var(--green); }

  /* ---------- cta band ---------- */
  .cta { max-width: 1240px; margin: 0 auto; padding: 0 32px 96px; }
  .cta-card {
    text-align: center; background: var(--dark); color: var(--on-dark); border-radius: 20px;
    padding: clamp(44px, 6vw, 80px) 32px;
  }
  .cta-card h2 {
    margin: 0 auto; max-width: 20ch; color: #fff; font-weight: 700; font-size: clamp(30px, 4.4vw, 52px);
    line-height: 1.04; letter-spacing: -0.02em;
  }
  .cta-lead { margin: 18px auto 0; max-width: 50ch; font-size: 16.5px; line-height: 1.6; color: var(--on-dark-muted); }
  .cta-card .btn-primary { margin-top: 28px; }

  /* ---------- modal ---------- */
  .modal[hidden] { display: none; }
  .modal {
    position: fixed; inset: 0; z-index: 90; display: flex; align-items: center; justify-content: center;
    padding: 24px;
  }
  .modal-backdrop {
    position: absolute; inset: 0; background: rgba(15, 12, 9, 0.55);
    -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px);
  }
  .modal-dialog {
    position: relative; width: min(780px, 100%); max-height: 88vh; overflow-y: auto;
    background: #f7f4ee; border-radius: 20px;
  }
  .modal-dialog:focus-visible { outline: none; }
  .modal-x {
    position: absolute; top: 16px; right: 16px; z-index: 2; width: 44px; height: 44px; border-radius: 50%;
    border: none; background: #fff; color: var(--ink); font-size: 18px; cursor: pointer;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
  }
  .modal-img { width: 100%; height: 220px; object-fit: cover; border-radius: 20px 20px 0 0; background: #ece7dd; }
  .modal-body { padding: 30px 34px 36px; }
  .modal-tag {
    margin: 0; font: 600 11px/1 'Hanken Grotesk', sans-serif; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--green);
  }
  .modal-titlerow { display: flex; align-items: baseline; gap: 12px; margin-top: 12px; }
  .modal-n { font: 700 16px/1 'Schibsted Grotesk', sans-serif; color: var(--terra); }
  .modal-title { margin: 0; font-weight: 700; font-size: clamp(24px, 4vw, 30px); letter-spacing: -0.02em; }
  .modal-desc { margin: 14px 0 24px; font-size: 15.5px; line-height: 1.6; color: var(--muted); max-width: 60ch; }
  .modal-eyebrow {
    margin: 0 0 14px; font: 600 11px/1 'Hanken Grotesk', sans-serif; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--muted);
  }
  .modal-products { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .modal-products li {
    background: #fff; border: 1px solid var(--line); border-radius: 13px; padding: 14px 16px;
    font: 600 15px/1.3 'Schibsted Grotesk', sans-serif; color: var(--ink);
  }
  .modal-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 26px; }

  /* ---------- responsive ---------- */
  @media (max-width: 880px) {
    .cards { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .head { padding: 56px 22px 28px; }
    .filter { padding: 8px 22px 0; }
    .grid-sec { padding: 28px 22px 64px; }
    .cards { grid-template-columns: 1fr; }
    .cta { padding: 0 22px 64px; }
    .modal { padding: 14px; }
    .modal-body { padding: 26px 22px 30px; }
  }
</style>

<script>
  // ---- Filter tabs: show/hide cards by data-tag, without reloading. ----
  const tabBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.tab'));
  const cardWraps = Array.from(document.querySelectorAll<HTMLLIElement>('.card-wrap'));

  function applyFilter(tag: string) {
    cardWraps.forEach((wrap) => {
      const show = tag === 'all' || wrap.getAttribute('data-tag') === tag;
      wrap.hidden = !show;
    });
  }

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      tabBtns.forEach((b) => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      applyFilter(btn.getAttribute('data-tag') || 'all');
    });
  });

  // ---- Quick-view modals: open/close with backdrop, ✕, and Escape. ----
  const pageContent = document.getElementById('page-content');
  let openModal: HTMLElement | null = null;
  let lastTrigger: HTMLElement | null = null;

  function open(id: string, trigger: HTMLElement) {
    const modal = document.getElementById(id);
    if (!modal) return;
    lastTrigger = trigger;
    openModal = modal;
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    // Focus trap: take the rest of the page out of the tab/AT order.
    if (pageContent) {
      pageContent.inert = true;
      pageContent.setAttribute('aria-hidden', 'true');
    }
    const dialog = modal.querySelector<HTMLElement>('.modal-dialog');
    dialog?.focus();
  }

  function close() {
    if (!openModal) return;
    openModal.hidden = true;
    document.body.style.overflow = '';
    if (pageContent) {
      pageContent.inert = false;
      pageContent.removeAttribute('aria-hidden');
    }
    lastTrigger?.focus();
    openModal = null;
    lastTrigger = null;
  }

  document.querySelectorAll<HTMLElement>('[data-modal-open]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const id = trigger.getAttribute('data-modal-open');
      if (id) open(id, trigger);
    });
  });

  document.querySelectorAll<HTMLElement>('[data-modal-close]').forEach((el) => {
    el.addEventListener('click', close);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && openModal) close();
  });
</script>
